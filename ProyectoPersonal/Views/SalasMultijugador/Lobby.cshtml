@model SalaJuego

<div class="min-h-[90vh] bg-slate-50 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-indigo-100 via-slate-50 to-white py-12 relative overflow-hidden">

    <div class="absolute top-20 right-10 w-72 h-72 bg-fuchsia-400/10 rounded-full blur-3xl animate-pulse pointer-events-none"></div>
    <div class="absolute bottom-10 left-20 w-96 h-96 bg-indigo-400/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

            <div class="lg:col-span-4 space-y-6">
                <div class="bg-white/80 backdrop-blur-xl rounded-[3rem] shadow-2xl shadow-indigo-100/50 p-8 border border-white text-center animate__animated animate__fadeInLeft">

                    <span class="inline-block px-4 py-1.5 bg-indigo-50 text-indigo-600 rounded-2xl text-[10px] font-black uppercase tracking-widest mb-4 border border-indigo-100">
                        <i class="bi bi-controller"></i> Misión Activa
                    </span>
                    <h2 class="text-3xl font-black text-slate-900 mb-2 leading-tight">@Model.NombreCuestionario</h2>
                    <p class="text-slate-400 text-xs font-bold uppercase tracking-widest mb-8">Anfitrión: <span class="text-slate-700">@Model.NombreAnfitrion</span></p>

                    <div class="bg-slate-900 rounded-[2rem] p-6 mb-8 shadow-inner relative overflow-hidden group">
                        <div class="absolute -right-4 -top-4 text-white/5 text-6xl transform rotate-12 group-hover:scale-110 transition-transform"><i class="bi bi-ticket-perforated-fill"></i></div>
                        <span class="block text-[10px] font-black text-indigo-400 uppercase tracking-[0.3em] mb-2 relative z-10">Código de Acceso</span>
                        <h1 class="text-6xl font-black text-white tracking-tighter relative z-10 drop-shadow-md">@Model.CodigoSala</h1>
                    </div>

                    <div class="inline-block p-4 bg-white rounded-3xl shadow-sm border-2 border-slate-100 mb-8 hover:shadow-md transition-shadow">
                        <div id="qrcode" class="mx-auto overflow-hidden rounded-xl"></div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-3 mb-0">Escanea para unirte</p>
                    </div>

                    <form asp-controller="SalasMultijugador" asp-action="EmpezarPartida" method="post">
                        <input type="hidden" name="idSala" value="@Model.IdSala" />
                        <input type="hidden" name="codigo" value="@Model.CodigoSala" />
                        <button type="submit" id="btn-empezar-main"
                                class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-black py-5 rounded-[2rem] text-lg tracking-tighter shadow-[0_8px_0_rgb(67,56,202)] hover:shadow-[0_6px_0_rgb(67,56,202)] hover:translate-y-[2px] active:shadow-none active:translate-y-[8px] transition-all flex items-center justify-center gap-3">
                            <i class="bi bi-rocket-takeoff-fill text-2xl"></i>
                            <span>INICIAR PARTIDA</span>
                        </button>
                    </form>
                    
                    <form id="form-destruir-sala" asp-controller="SalasMultijugador" asp-action="CancelarSalaManual" method="post">
                        <input type="hidden" name="idSala" value="@Model.IdSala" />
                        <button type="button" onclick="confirmarDestruccion()" 
                                class="w-full mt-4 bg-white dark:bg-slate-800 text-rose-500 hover:bg-rose-50 hover:text-rose-600 dark:hover:bg-rose-900/30 border-2 border-rose-100 dark:border-rose-900/50 font-black py-4 rounded-[2rem] text-sm tracking-widest transition-all flex items-center justify-center gap-2">
                            <i class="bi bi-x-circle-fill text-lg"></i> CANCELAR Y CERRAR SALA
                        </button>
                    </form>
                    
                </div>
            </div>

            <div class="lg:col-span-5 space-y-6">
                <div class="bg-white/80 backdrop-blur-xl rounded-[3rem] shadow-2xl shadow-slate-200/50 p-8 border border-white min-h-[600px] flex flex-col animate__animated animate__fadeInUp">

                    <div class="flex justify-between items-center mb-8 pb-6 border-b border-slate-100">
                        <div>
                            <h3 class="text-2xl font-black text-slate-900 tracking-tight flex items-center gap-3">
                                <i class="bi bi-people-fill text-indigo-500"></i> Jugadores
                            </h3>
                            <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-1">Esperando rivales...</p>
                        </div>
                        <div class="bg-indigo-50 border border-indigo-100 text-indigo-700 px-5 py-2.5 rounded-2xl font-black text-lg shadow-sm flex items-center gap-2">
                            <span class="relative flex h-3 w-3">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-3 w-3 bg-indigo-500"></span>
                            </span>
                            <span id="contador">0</span> <span class="text-indigo-300 mx-1">/</span> @Model.CapacidadMaxima
                        </div>
                    </div>

                    <div id="contenedor-participantes" class="grid grid-cols-1 sm:grid-cols-2 gap-4 flex-grow content-start">
                    </div>
                </div>
            </div>

            <div class="lg:col-span-3">
                <div class="bg-slate-900 rounded-[3rem] shadow-2xl p-8 border border-slate-800 h-[600px] flex flex-col animate__animated animate__fadeInRight">

                    <h3 class="text-xl font-black text-white mb-2 flex items-center gap-3">
                        <i class="bi bi-person-lines-fill text-fuchsia-500"></i> Invitar Amigos
                    </h3>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-6 pb-6 border-b border-slate-800">Conecta con tu equipo</p>

                    <div class="space-y-4 overflow-y-auto flex-grow pr-2 custom-scrollbar">
                        @if (ViewBag.Amigos != null && ((List<UsuarioAmistad>)ViewBag.Amigos).Count > 0)
                        {
                            foreach (var amigo in (List<UsuarioAmistad>)ViewBag.Amigos)
                            {
                                <div class="flex flex-col p-4 bg-slate-800/50 rounded-2xl border border-slate-700/50 hover:bg-slate-800 transition-all group">
                                    <div class="flex items-center gap-3 mb-4">
                                        <div class="relative">
                                            <div class="w-10 h-10 bg-slate-700 rounded-xl flex items-center justify-center shadow-inner font-black text-white text-lg">
                                                @amigo.Nombre.Substring(0, 1).ToUpper()
                                            </div>
                                            <div class="absolute -bottom-1 -right-1 w-3 h-3 bg-emerald-500 border-2 border-slate-800 rounded-full"></div>
                                        </div>
                                        <strong class="text-slate-200 truncate">@amigo.Nombre</strong>
                                    </div>
                                    <button class="w-full py-2.5 bg-white/5 border border-white/10 rounded-xl text-[10px] font-black text-slate-300 uppercase tracking-widest hover:bg-fuchsia-600 hover:text-white hover:border-fuchsia-500 transition-all shadow-sm active:scale-95"
                                            onclick="enviarInvitacion(this, '@amigo')">
                                        Enviar Invitación
                                    </button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-16 opacity-30 flex flex-col items-center">
                                <i class="bi bi-radar text-6xl mb-4 animate-[spin_4s_linear_infinite]"></i>
                                <p class="text-[10px] font-black uppercase tracking-widest text-white">Ningún amigo detectado en el radar</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 10px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.4);
        }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    <script>
        function confirmarDestruccion() {
            Swal.fire({
                title: '¿Destruir la sala?',
                text: "Todos los jugadores serán expulsados y el código de acceso dejará de funcionar. ¡Esta acción no se puede deshacer!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f43f5e',
                cancelButtonColor: '#64748b',
                confirmButtonText: '<i class="bi bi-explosion"></i> Sí, destruirla',
                cancelButtonText: 'Cancelar',
                background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#ffffff',
                color: document.documentElement.classList.contains('dark') ? '#f1f5f9' : '#0f172a'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('form-destruir-sala').submit();
                }
            });
        }

        async function enviarInvitacion(btn, nombreAmigo) {
            btn.disabled = true;
            btn.innerHTML = '<span class="animate-spin inline-block h-3 w-3 border-2 border-white border-t-transparent rounded-full"></span>';

            try {
                const formData = new URLSearchParams();
                formData.append("nombreAmigo", nombreAmigo);
                formData.append("codigoSala", "@Model.CodigoSala");

                const response = await fetch("/Datos/EnviarInvitacionPartida", {
                    method: "POST",
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: formData
                });

                if (!response.ok) throw new Error("Error");

                btn.className = "w-full py-2.5 bg-emerald-500 border border-emerald-400 rounded-xl text-[10px] font-black text-white uppercase tracking-widest shadow-sm shadow-emerald-500/30";
                btn.innerHTML = '<i class="bi bi-check-lg text-sm"></i> ENVIADA';

            } catch (error) {
                btn.disabled = false;
                btn.innerHTML = 'REINTENTAR';
                btn.classList.add("bg-rose-500", "text-white", "border-rose-400");
            }
        }

        document.addEventListener("DOMContentLoaded", () => {
            const urlAcceso = window.location.origin + "/SalasMultijugador/Unirse?codigoSala=@Model.CodigoSala";
            new QRCode(document.getElementById("qrcode"), {
                text: urlAcceso,
                width: 160,
                height: 160,
                colorDark: "#0f172a",
                colorLight: "#ffffff",
                correctLevel : QRCode.CorrectLevel.H
            });

            let totalJugadores = 0;
            const contadorElement = document.getElementById("contador");
            const contenedorParticipantes = document.getElementById("contenedor-participantes");
            const btnEmpezar = document.getElementById("btn-empezar-main");

            async function actualizarLobby() {
                try {
                    const response = await fetch(`/Datos/ActualizarParticipantes?codigoPartida=@Model.CodigoSala`);
                    if (!response.ok) throw new Error("Error en la conexión");

                    const participantes = await response.json();

                    if (participantes.length !== totalJugadores) {
                        totalJugadores = participantes.length;
                        contadorElement.textContent = totalJugadores;

                        contenedorParticipantes.innerHTML = "";

                        participantes.forEach(p => {
                            let esHost = p.idUsuario == @Model.IdAnfitrion;

                            let containerClasses = esHost
                                ? "bg-amber-50 border-2 border-amber-300 shadow-amber-100/50"
                                : "bg-slate-50 border-2 border-transparent hover:border-indigo-200";

                            let hostBadge = esHost
                                ? `<div class="absolute -top-3 -right-2 bg-amber-400 text-white text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-full shadow-md border-2 border-white transform rotate-6 animate-pulse">Host <i class="bi bi-star-fill ml-1"></i></div>`
                                : '';

                            let nombreAvatar = p.avatar ? p.avatar : 'avatar1.png';
                            let avatarUrl = `/images/avatares/${nombreAvatar}`;

                            contenedorParticipantes.insertAdjacentHTML('beforeend', `
                                <div class="relative p-4 rounded-3xl shadow-sm flex items-center gap-4 transition-all animate__animated animate__zoomIn ${containerClasses}">
                                    ${hostBadge}
                                    <div class="flex-shrink-0">
                                        <img src="${avatarUrl}" class="w-14 h-14 rounded-2xl bg-white shadow-inner border-2 ${esHost ? 'border-amber-400' : 'border-indigo-200'} object-cover" alt="Avatar de ${p.nombre}" />
                                    </div>
                                    <div class="flex-grow overflow-hidden">
                                        <div class="font-black text-slate-800 text-lg truncate">${p.nombre}</div>
                                        <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">En posición</div>
                                    </div>
                                </div>
                            `);
                        });

                        if (totalJugadores >= @Model.CapacidadMaxima && @Model.CapacidadMaxima > 0) {
                            btnEmpezar.innerHTML = '<span class="animate-spin inline-block h-5 w-5 border-4 border-white border-t-transparent rounded-full mr-3"></span>SALA LLENA. INICIANDO...';
                            btnEmpezar.disabled = true;

                            btnEmpezar.className = "w-full bg-amber-500 text-white font-black py-5 rounded-[2rem] text-lg tracking-tighter shadow-[0_8px_0_rgb(217,119,6)] transition-all flex items-center justify-center gap-3";

                            setTimeout(() => {
                                document.getElementById("btn-empezar-main").closest("form").submit();
                            }, 2000);
                        }
                    }
                } catch (error) {
                    console.error("Fallo actualizando el lobby:", error);
                }
            }

            setInterval(actualizarLobby, 2500);
            actualizarLobby();
        });
    </script>
}