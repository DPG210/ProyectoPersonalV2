@model List<SalaJuego>

@* --- ENVOLTORIO CON DEGRADADO SUAVE Y MODO OSCURO --- *@
<div class="min-h-screen bg-slate-50 dark:bg-slate-900 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-100/50 via-slate-50 to-slate-100 dark:from-indigo-900/40 dark:via-slate-900 dark:to-slate-800 px-4 py-12 relative overflow-hidden transition-colors duration-500">

    @* Decoración de fondo flotante *@
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-indigo-300/10 dark:bg-indigo-500/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-fuchsia-300/10 dark:bg-fuchsia-500/10 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto relative z-10">

        @* --- BOTÓN VOLVER --- *@
        <div class="mb-6 animate__animated animate__fadeInLeft">
            <a asp-action="Index" asp-controller="Partidas" class="group inline-flex items-center gap-2 text-[10px] font-black text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all uppercase tracking-[0.2em] bg-white/60 dark:bg-slate-800/60 hover:bg-white dark:hover:bg-slate-800 backdrop-blur-md px-5 py-2.5 rounded-full shadow-sm hover:shadow-md border border-slate-200/60 dark:border-slate-700/60 active:scale-95">
                <i class="bi bi-arrow-left text-base group-hover:-translate-x-1 transition-transform"></i> Volver al menú
            </a>
        </div>

        @* --- ENCABEZADO --- *@
        <div class="text-center mb-10 animate__animated animate__fadeInDown">
            <div class="inline-flex items-center justify-center w-24 h-24 bg-white dark:bg-slate-800 rounded-[2rem] mb-6 shadow-xl shadow-indigo-100/50 dark:shadow-indigo-900/20 border border-slate-50 dark:border-slate-700 transform rotate-3 hover:rotate-0 transition-all">
                <i class="bi bi-radar text-5xl text-indigo-600 dark:text-indigo-400 animate-[spin_4s_linear_infinite]"></i>
            </div>
            <h1 class="text-5xl font-black text-slate-900 dark:text-white tracking-tighter">Explorador de <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-fuchsia-500 dark:from-indigo-400 dark:to-fuchsia-400">Salas</span></h1>
            <p class="text-slate-500 dark:text-slate-400 font-bold mt-3 text-lg">Busca, únete y demuestra tu conocimiento en la arena global.</p>
        </div>

        @* --- BARRA DE FILTROS --- *@
        @if (Model != null && Model.Count > 0)
        {
            <div class="mb-10 bg-white/60 dark:bg-slate-800/60 backdrop-blur-md p-4 rounded-3xl shadow-sm border border-slate-200 dark:border-slate-700 flex flex-col md:flex-row gap-4 animate__animated animate__fadeIn">

                @* Buscador de texto *@
                <div class="relative flex-grow group">
                    <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 group-focus-within:text-indigo-500 dark:group-focus-within:text-indigo-400 transition-colors pointer-events-none">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" id="filtroTexto" placeholder="Buscar por título o anfitrión..."
                           class="w-full bg-white dark:bg-slate-900 border-2 border-slate-100 dark:border-slate-700 focus:border-indigo-500 dark:focus:border-indigo-400 rounded-2xl py-3 pl-12 pr-4 font-bold text-slate-700 dark:text-slate-200 outline-none transition-all shadow-sm placeholder-slate-400 dark:placeholder-slate-500" />
                </div>

                @* Filtro por Modo de Juego *@
                <div class="relative min-w-[200px] group">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-fuchsia-400 pointer-events-none">
                        <i class="bi bi-controller"></i>
                    </span>
                    <select id="filtroModo" class="w-full bg-white dark:bg-slate-900 border-2 border-slate-100 dark:border-slate-700 focus:border-fuchsia-500 dark:focus:border-fuchsia-400 rounded-2xl py-3 pl-10 pr-8 font-bold text-slate-700 dark:text-slate-200 outline-none transition-all shadow-sm appearance-none cursor-pointer">
                        <option value="todos">Todos los modos</option>
                        <option value="quizz">Quizz Clásico</option>
                        <option value="trivial">Trivial Completo</option>
                    </select>
                    <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 pointer-events-none"><i class="bi bi-chevron-down"></i></span>
                </div>
            </div>
        }

        @if (Model == null || Model.Count == 0)
        {
            @* --- ESTADO VACÍO --- *@
            <div class="bg-white/60 dark:bg-slate-800/60 backdrop-blur-md rounded-[3rem] p-16 text-center max-w-2xl mx-auto border-2 border-dashed border-indigo-200 dark:border-indigo-900/50 shadow-xl shadow-indigo-100/20 dark:shadow-black/20 animate__animated animate__fadeInUp">
                <div class="w-32 h-32 bg-slate-100 dark:bg-slate-900 rounded-full flex items-center justify-center mx-auto mb-8 relative border border-slate-200 dark:border-slate-700">
                    <i class="bi bi-controller text-6xl text-slate-300 dark:text-slate-600"></i>
                    <div class="absolute -bottom-2 -right-2 text-4xl">🏜️</div>
                </div>
                <h3 class="text-3xl font-black text-slate-800 dark:text-white mb-3 tracking-tight">El desierto está vacío</h3>
                <p class="text-slate-500 dark:text-slate-400 font-medium mb-10 text-lg">No hay partidas públicas en este momento. ¡Sé el primero en levantar una sala y que empiece la batalla!</p>
                <a asp-action="Index" asp-controller="Partidas" class="inline-flex items-center justify-center gap-3 bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-500 hover:to-violet-500 text-white font-black px-12 py-5 rounded-[2rem] text-lg shadow-[0_8px_0_rgb(67,56,202)] hover:translate-y-[2px] hover:shadow-[0_6px_0_rgb(67,56,202)] active:translate-y-[8px] active:shadow-none transition-all">
                    <i class="bi bi-plus-circle-fill"></i> CREAR PARTIDA AHORA
                </a>
            </div>
        }
        else
        {
            @* --- GRID DE SALAS PÚBLICAS --- *@
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8" id="contenedor-salas">
                @foreach (var sala in Model)
                {
                    <div class="tarjeta-sala group relative animate__animated animate__zoomIn"
                         data-nombre="@(sala.NombreCuestionario?.ToLower() ?? "")"
                         data-anfitrion="@(sala.NombreAnfitrion?.ToLower() ?? "")"
                         data-modo="@(sala.TipoJuego?.ToLower() ?? "")">

                        @* Tarjeta Principal *@
                        <div class="bg-white/80 dark:bg-slate-800/80 backdrop-blur-xl rounded-[2.5rem] h-full flex flex-col overflow-hidden transition-all duration-500 hover:-translate-y-3 hover:shadow-2xl hover:shadow-indigo-200/50 dark:hover:shadow-indigo-900/20 border-2 border-white dark:border-slate-700 group-hover:border-indigo-100 dark:group-hover:border-indigo-500/30">

                            @* Header *@
                            <div class="p-8 relative overflow-hidden bg-gradient-to-br from-slate-50 to-white dark:from-slate-800 dark:to-slate-700/50 border-b border-slate-100 dark:border-slate-600">
                                <div class="absolute -right-10 -top-10 text-9xl text-indigo-50 dark:text-indigo-500/5 transform rotate-12 group-hover:rotate-0 transition-transform duration-700 pointer-events-none">
                                    <i class="bi bi-joystick"></i>
                                </div>

                                <div class="flex justify-between items-start gap-4 relative z-10">
                                    <h5 class="text-xl font-black text-slate-800 dark:text-white leading-tight line-clamp-2 tracking-tight group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                                        @sala.NombreCuestionario
                                    </h5>
                                    <div class="bg-white dark:bg-slate-900 border border-indigo-100 dark:border-indigo-900/50 text-indigo-600 dark:text-indigo-400 text-xs font-black px-3 py-1.5 rounded-xl flex items-center gap-1.5 shadow-sm whitespace-nowrap">
                                        <i class="bi bi-people-fill"></i> @sala.TotalJugadores <span class="text-indigo-300 dark:text-indigo-700">/</span> @sala.CapacidadMaxima
                                    </div>
                                </div>
                            </div>

                            @* Cuerpo *@
                            <div class="p-8 flex-grow space-y-6 bg-white/50 dark:bg-slate-800/50">

                                @* Organizador *@
                                <div class="flex items-center gap-4 bg-white dark:bg-slate-900 p-3 rounded-[1.5rem] shadow-sm border border-slate-50 dark:border-slate-700 group-hover:shadow-md transition-shadow">
                                    <div class="w-12 h-12 bg-indigo-50 dark:bg-indigo-900/30 rounded-xl overflow-hidden border-2 border-indigo-100 dark:border-indigo-800 flex-shrink-0">
                                        <img src="https://api.dicebear.com/7.x/bottts/svg?seed=@sala.NombreAnfitrion&backgroundColor=c7d2fe" alt="Avatar" class="w-full h-full object-cover dark:opacity-90" />
                                    </div>
                                    <div class="overflow-hidden">
                                        <span class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] leading-none mb-1">Host de Sala</span>
                                        <span class="font-black text-slate-700 dark:text-slate-200 text-lg truncate block">@sala.NombreAnfitrion</span>
                                    </div>
                                </div>

                                @* Estadísticas *@
                                <div class="grid grid-cols-2 gap-3">
                                    <div class="bg-slate-50 dark:bg-slate-900 p-3 rounded-2xl border border-slate-100 dark:border-slate-700 flex flex-col items-center justify-center text-center">
                                        <i class="bi bi-controller text-xl text-fuchsia-500 dark:text-fuchsia-400 mb-1"></i>
                                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-0.5">Modo</span>
                                        <span class="font-bold text-slate-700 dark:text-slate-200 text-sm capitalize">@sala.TipoJuego</span>
                                    </div>
                                    <div class="bg-slate-50 dark:bg-slate-900 p-3 rounded-2xl border border-slate-100 dark:border-slate-700 flex flex-col items-center justify-center text-center">
                                        <i class="bi bi-list-ol text-xl text-indigo-500 dark:text-indigo-400 mb-1"></i>
                                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-0.5">Preguntas</span>
                                        <span class="font-bold text-slate-700 dark:text-slate-200 text-sm">@sala.CantidadPreguntas Rondas</span>
                                    </div>
                                </div>
                            </div>

                            @* Footer de Acción *@
                            <div class="p-4 pt-0 mt-auto">
                                <a asp-controller="SalasMultijugador" asp-action="Unirse" asp-route-codigoSala="@sala.CodigoSala"
                                   class="relative block w-full overflow-hidden rounded-2xl bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 font-black text-center py-4 tracking-widest uppercase transition-all group-hover:shadow-[0_4px_0_rgb(67,56,202)] group-hover:-translate-y-1 active:translate-y-0 active:shadow-none">
                                    <span class="absolute inset-0 bg-indigo-600 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"></span>
                                    <span class="relative z-10 flex items-center justify-center gap-2 group-hover:text-white transition-colors duration-300">
                                        <i class="bi bi-door-open-fill text-lg"></i>
                                        <span>UNIRME AHORA</span>
                                    </span>
                                </a>
                            </div>

                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<script>
    // Lógica de filtrado en cliente
    document.addEventListener("DOMContentLoaded", () => {
        const inputTexto = document.getElementById("filtroTexto");
        const selectModo = document.getElementById("filtroModo");
        const tarjetas = document.querySelectorAll(".tarjeta-sala");

        function filtrarSalas() {
            const texto = inputTexto.value.toLowerCase().trim();
            const modo = selectModo.value.toLowerCase();

            tarjetas.forEach(tarjeta => {
                const nombre = tarjeta.getAttribute("data-nombre");
                const anfitrion = tarjeta.getAttribute("data-anfitrion");
                const modoTarjeta = tarjeta.getAttribute("data-modo");

                // Comprueba coincidencias
                const coincideTexto = nombre.includes(texto) || anfitrion.includes(texto);
                const coincideModo = modo === "todos" || modoTarjeta.includes(modo);

                // Aplica visibilidad
                if (coincideTexto && coincideModo) {
                    tarjeta.style.display = "block";
                } else {
                    tarjeta.style.display = "none";
                }
            });
        }

        // Asignar eventos si existen los elementos
        if (inputTexto && selectModo) {
            inputTexto.addEventListener("input", filtrarSalas);
            selectModo.addEventListener("change", filtrarSalas);
        }
    });
</script>