<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Trivial Challenge</title>

    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <script>
        // Solo activamos el modo oscuro si el usuario pulsó la luna en una visita anterior
        if (localStorage.getItem('color-theme') === 'dark') {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }

        // La función que apaga y enciende las luces
        function toggleDarkMode() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('color-theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('color-theme', 'dark');
            }
        }
    </script>
</head>
<body class="bg-slate-50 text-slate-800 dark:bg-slate-950 dark:text-slate-100 font-sans min-h-screen flex flex-col transition-colors duration-300 selection:bg-violet-200 selection:text-violet-900">

    @* --- CONTENIDO PRINCIPAL --- *@
    <div class="flex-grow flex flex-col relative">
        <main role="main" class="flex-grow w-full flex flex-col">
            @RenderBody()
        </main>
    </div>

    @* --- BOTÓN FLOTANTE DARK MODE GLOBAL --- *@
    <button onclick="toggleDarkMode()" title="Alternar Modo Oscuro" class="fixed bottom-6 left-6 z-50 w-12 h-12 rounded-full flex items-center justify-center bg-white/80 dark:bg-slate-800/80 backdrop-blur-md border border-slate-200 dark:border-slate-700 shadow-lg hover:scale-110 hover:shadow-xl transition-all text-slate-600 dark:text-amber-400 focus:outline-none group">
        <i class="bi bi-moon-stars-fill block dark:hidden text-xl group-hover:-rotate-12 transition-transform"></i>
        <i class="bi bi-sun-fill hidden dark:block text-xl group-hover:rotate-45 transition-transform duration-500"></i>
    </button>

    @* --- FOOTER MINIMALISTA --- *@
    <footer class="bg-transparent py-4 shrink-0 relative z-40 pointer-events-none">
        <div class="max-w-7xl mx-auto px-4 flex flex-col items-center justify-center">
            <p class="text-slate-400 dark:text-slate-600 text-[10px] font-black tracking-widest uppercase">
                &copy; 2026 - Trivial Challenge
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <div id="modalAnuncio" class="fixed inset-0 z-[100] hidden bg-slate-900/90 backdrop-blur-xl flex items-center justify-center">

        <div class="relative w-full max-w-4xl bg-black rounded-3xl overflow-hidden shadow-2xl shadow-indigo-500/20 border border-slate-800">

            <div class="absolute top-0 left-0 right-0 p-4 flex justify-between items-center bg-gradient-to-b from-black/80 to-transparent z-10">
                <div id="txtContadorAnuncio" class="bg-black/50 text-white text-xs font-black uppercase tracking-widest px-4 py-2 rounded-full border border-white/10 backdrop-blur-sm">
                    El anuncio se puede saltar en 15s
                </div>

                <button id="btnCerrarAnuncio" onclick="cerrarYReclamarAnuncio()" class="hidden bg-slate-800 hover:bg-rose-500 text-white rounded-full w-10 h-10 flex items-center justify-center transition-colors shadow-lg border border-white/10">
                    <i class="bi bi-x-lg font-black"></i>
                </button>
            </div>

            <video id="videoAnuncio" class="w-full h-[60vh] object-cover pointer-events-none" playsinline>
                <source id="videoSource" src="" type="video/mp4">
                Tu navegador no soporta vídeos.
            </video>

            <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/80 to-transparent flex items-center gap-4 z-10">
                <div class="w-10 h-10 bg-indigo-500 rounded-xl flex items-center justify-center text-white text-xl">
                    <i class="bi bi-controller"></i>
                </div>
                <div>
                    <p class="text-white font-black text-sm uppercase tracking-wider">Patrocinador del Trivial</p>
                    <p class="text-slate-400 text-xs">Apoya el juego viendo este clip</p>
                </div>
            </div>

        </div>
    </div>
</body>
</html>