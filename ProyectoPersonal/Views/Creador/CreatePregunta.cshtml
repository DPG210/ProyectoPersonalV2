@model List<string>

@* --- ENVOLTORIO DINÁMICO --- *@
<div class="min-h-screen bg-slate-50 dark:bg-slate-900 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-100/60 via-slate-50 to-fuchsia-50 dark:from-indigo-900/40 dark:via-slate-900 dark:to-fuchsia-900/20 py-12 px-4 relative overflow-hidden transition-colors duration-500">

    @* Luces de fondo *@
    <div class="absolute top-0 right-20 w-[400px] h-[400px] bg-indigo-300/20 dark:bg-indigo-500/10 rounded-full blur-[100px] animate-pulse pointer-events-none"></div>
    <div class="absolute bottom-0 left-10 w-[300px] h-[300px] bg-fuchsia-300/20 dark:bg-fuchsia-500/10 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto relative z-10">

        @* --- TARJETA PRINCIPAL (Glassmorphism) --- *@
        <div class="bg-white/80 dark:bg-slate-800/80 backdrop-blur-xl rounded-[3rem] shadow-2xl shadow-indigo-100/50 dark:shadow-black/50 border border-white dark:border-slate-700 p-8 md:p-12 animate__animated animate__fadeInUp transition-colors duration-300">

            @* ENCABEZADO *@
            <div class="text-center mb-12">
                <div class="relative inline-flex mb-6 group">
                    <div class="absolute inset-0 bg-fuchsia-500 rounded-[2rem] blur-xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
                    <div class="relative bg-gradient-to-br from-indigo-600 to-fuchsia-500 text-white w-20 h-20 rounded-[1.5rem] flex items-center justify-center text-4xl shadow-2xl transform group-hover:scale-105 transition-transform duration-300">
                        <i class="bi bi-patch-plus-fill"></i>
                    </div>
                </div>
                <h2 class="text-4xl font-black text-slate-900 dark:text-white tracking-tighter mb-2">Laboratorio de Preguntas</h2>
                <p class="text-slate-500 dark:text-slate-400 font-bold text-sm uppercase tracking-widest">Sintetiza nuevos desafíos para la comunidad</p>
            </div>

            @* --- FORMULARIO --- *@
            <form asp-action="CreatePregunta" method="post" class="space-y-10">

                @* SECCIÓN 1: UBICACIÓN (Adaptada para usar ViewBag.MisCuestionarios) *@
                <div class="bg-slate-50/80 dark:bg-slate-900/50 p-8 rounded-[2rem] border border-slate-100 dark:border-slate-700/50 shadow-inner">
                    <h4 class="text-xs font-black text-indigo-500 dark:text-indigo-400 uppercase tracking-[0.2em] mb-6 flex items-center gap-2">
                        <i class="bi bi-folder2-open text-lg"></i> 1. Destino del Archivo
                    </h4>

                    <div class="relative group">
                        <span class="absolute left-6 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 group-focus-within:text-indigo-500 dark:group-focus-within:text-indigo-400 transition-colors pointer-events-none">
                            <i class="bi bi-journal-bookmark-fill"></i>
                        </span>
                        <select name="IdCuestionario" class="w-full bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 focus:border-indigo-500 dark:focus:border-indigo-400 rounded-2xl py-4 pl-14 pr-6 font-bold text-slate-700 dark:text-slate-200 outline-none transition-all shadow-sm cursor-pointer appearance-none" required>
                            <option value="" selected disabled>-- Selecciona uno de tus cuestionarios --</option>
                            @if (ViewBag.MisCuestionarios != null)
                            {
                                foreach (var cuest in ViewBag.MisCuestionarios)
                                {
                                    @* CUIDADO: Verifica si la propiedad de tu modelo es Titulo o Nombre *@
                                    <option value="@cuest.IdCuestionario">@cuest.Titulo</option>
                                }
                            }
                        </select>
                        <span class="absolute right-6 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 pointer-events-none"><i class="bi bi-chevron-down"></i></span>
                    </div>
                </div>

                @* SECCIÓN 2: EL CONTENIDO *@
                <div class="space-y-8">
                    <h4 class="text-xs font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2 border-b border-slate-100 dark:border-slate-700 pb-4">
                        <i class="bi bi-pencil-square text-lg"></i> 2. Formulación de la Pregunta
                    </h4>

                    @* Enunciado *@
                    <div class="relative group">
                        <span class="absolute left-6 top-6 text-slate-300 dark:text-slate-600 group-focus-within:text-fuchsia-500 dark:group-focus-within:text-fuchsia-400 transition-colors pointer-events-none">
                            <i class="bi bi-quote text-3xl"></i>
                        </span>
                        <textarea name="Enunciado" class="w-full bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 focus:border-fuchsia-500 dark:focus:border-fuchsia-400 rounded-[2rem] py-6 pl-16 pr-8 text-xl font-black text-slate-800 dark:text-white outline-none transition-all shadow-sm min-h-[140px] resize-none placeholder-slate-300 dark:placeholder-slate-600"
                                  required placeholder="Ej: ¿Cuál es el único satélite natural de la Tierra?"></textarea>
                    </div>

                    @* Grid de Respuestas *@
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-slate-50 dark:bg-slate-900/50 p-6 rounded-[2.5rem] border border-slate-100 dark:border-slate-700/50">

                        @* Correcta *@
                        <div class="space-y-2 md:col-span-2">
                            <label class="block text-[10px] font-black text-emerald-600 dark:text-emerald-400 uppercase tracking-widest ml-4">La Verdad Absoluta (Correcta)</label>
                            <div class="relative group">
                                <span class="absolute left-5 top-1/2 -translate-y-1/2 text-emerald-500 group-focus-within:scale-125 transition-transform"><i class="bi bi-check-circle-fill text-xl"></i></span>
                                <input type="text" name="OpcionCorrecta" class="w-full bg-emerald-50/50 dark:bg-emerald-950/20 border-2 border-emerald-200 dark:border-emerald-800 focus:border-emerald-500 focus:bg-white dark:focus:bg-slate-800 rounded-2xl py-4 pl-14 pr-6 font-bold text-emerald-900 dark:text-emerald-100 outline-none transition-all shadow-inner placeholder-emerald-300/50 dark:placeholder-emerald-800/50" required placeholder="Escribe la respuesta correcta aquí..." />
                            </div>
                        </div>

                        @* Incorrectas *@
                        <div class="space-y-2">
                            <label class="block text-[10px] font-black text-rose-500 dark:text-rose-400 uppercase tracking-widest ml-4">Distracción 1</label>
                            <div class="relative group">
                                <span class="absolute left-5 top-1/2 -translate-y-1/2 text-rose-400 group-focus-within:scale-125 transition-transform"><i class="bi bi-x-circle text-lg"></i></span>
                                <input type="text" name="OpcionIncorrecta1" class="w-full bg-white dark:bg-slate-800 border-2 border-rose-100 dark:border-rose-900/30 focus:border-rose-400 rounded-2xl py-4 pl-14 pr-6 font-bold text-slate-700 dark:text-slate-200 outline-none transition-all shadow-sm placeholder-slate-300 dark:placeholder-slate-600" required placeholder="Opción falsa..." />
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="block text-[10px] font-black text-rose-500 dark:text-rose-400 uppercase tracking-widest ml-4">Distracción 2</label>
                            <div class="relative group">
                                <span class="absolute left-5 top-1/2 -translate-y-1/2 text-rose-400 group-focus-within:scale-125 transition-transform"><i class="bi bi-x-circle text-lg"></i></span>
                                <input type="text" name="OpcionIncorrecta2" class="w-full bg-white dark:bg-slate-800 border-2 border-rose-100 dark:border-rose-900/30 focus:border-rose-400 rounded-2xl py-4 pl-14 pr-6 font-bold text-slate-700 dark:text-slate-200 outline-none transition-all shadow-sm placeholder-slate-300 dark:placeholder-slate-600" required placeholder="Opción falsa..." />
                            </div>
                        </div>

                        <div class="space-y-2 md:col-span-2 sm:w-1/2 sm:mx-auto">
                            <label class="block text-[10px] font-black text-rose-500 dark:text-rose-400 uppercase tracking-widest ml-4">Distracción 3</label>
                            <div class="relative group">
                                <span class="absolute left-5 top-1/2 -translate-y-1/2 text-rose-400 group-focus-within:scale-125 transition-transform"><i class="bi bi-x-circle text-lg"></i></span>
                                <input type="text" name="OpcionIncorrecta3" class="w-full bg-white dark:bg-slate-800 border-2 border-rose-100 dark:border-rose-900/30 focus:border-rose-400 rounded-2xl py-4 pl-14 pr-6 font-bold text-slate-700 dark:text-slate-200 outline-none transition-all shadow-sm placeholder-slate-300 dark:placeholder-slate-600" required placeholder="Opción falsa..." />
                            </div>
                        </div>
                    </div>
                </div>

                @* SECCIÓN 3: DETALLES EXTRA *@
                <div class="grid grid-cols-1 md:grid-cols-12 gap-6 pt-6 border-t border-slate-100 dark:border-slate-700">
                    <div class="md:col-span-4 space-y-2">
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Nivel de Dificultad</label>
                        <div class="relative">
                            <select name="Nivel" class="w-full bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-600 focus:border-indigo-500 dark:focus:border-indigo-400 rounded-2xl py-4 px-6 font-bold text-slate-700 dark:text-slate-200 outline-none transition-all shadow-sm cursor-pointer appearance-none">
                                <option value="1">🟢 Básico (Nivel 1)</option>
                                <option value="2">🟡 Intermedio (Nivel 2)</option>
                                <option value="3">🟠 Avanzado (Nivel 3)</option>
                                <option value="4">🔴 Experto (Nivel 4)</option>
                            </select>
                            <span class="absolute right-6 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"><i class="bi bi-chevron-down"></i></span>
                        </div>
                    </div>

                    <div class="md:col-span-8 space-y-2">
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Dato Curioso / Explicación</label>
                        <div class="relative group">
                            <span class="absolute left-5 top-1/2 -translate-y-1/2 text-amber-400 group-focus-within:text-amber-500 transition-colors pointer-events-none">
                                <i class="bi bi-lightbulb-fill text-xl"></i>
                            </span>
                            <input type="text" name="ExplicacionDidactica" class="w-full bg-amber-50/30 dark:bg-amber-950/20 border-2 border-amber-100 dark:border-amber-900/50 focus:border-amber-400 focus:bg-white dark:focus:bg-slate-800 rounded-2xl py-4 pl-14 pr-6 font-medium text-slate-700 dark:text-slate-300 outline-none transition-all shadow-inner placeholder-slate-400 dark:placeholder-slate-600" placeholder="Ayuda al jugador a aprender tras responder..." />
                        </div>
                    </div>
                </div>

                @* BOTÓN DE ACCIÓN 3D *@
                <div class="pt-8">
                    <button type="submit"
                            class="group relative w-full bg-gradient-to-r from-indigo-600 to-fuchsia-600 hover:from-indigo-500 hover:to-fuchsia-500 text-white font-black py-5 rounded-[2rem] text-xl tracking-tighter shadow-[0_8px_0_rgb(67,56,202)] hover:shadow-[0_6px_0_rgb(67,56,202)] hover:translate-y-[2px] active:shadow-none active:translate-y-[8px] transition-all flex items-center justify-center gap-3">
                        <i class="bi bi-save2-fill text-2xl group-hover:scale-110 transition-transform"></i>
                        <span>INYECTAR PREGUNTA AL SISTEMA</span>
                    </button>

                    <div class="text-center mt-10">
                        <a asp-action="Index" class="inline-flex items-center gap-2 text-xs font-black text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors uppercase tracking-[0.2em] group">
                            <i class="bi bi-arrow-left text-lg group-hover:-translate-x-1 transition-transform"></i> Volver a la central
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>