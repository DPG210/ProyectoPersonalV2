@model List<int>

<div class="min-h-[90vh] bg-red-50 dark:bg-slate-950 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-red-100 via-white to-red-50 dark:from-red-900/20 dark:via-slate-950 dark:to-black font-sans text-slate-800 dark:text-slate-100 p-4 sm:p-8 rounded-[3rem] border-4 border-red-200 dark:border-red-950 shadow-[0_0_50px_rgba(220,38,38,0.1)] dark:shadow-[0_0_100px_rgba(220,38,38,0.15)] overflow-hidden relative transition-colors duration-500">
    @if (Model != null && Model.Any())
    {
        <div class="max-w-4xl mx-auto mt-4 relative z-10">
            <div class="flex justify-end mb-6">
                <button onclick="abrirModalReporte()" class="text-red-600 dark:text-red-900 hover:text-red-800 dark:hover:text-red-500 transition-all flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.2em] bg-white/80 dark:bg-black/40 px-5 py-2 rounded-full border border-red-200 dark:border-red-900/40 hover:border-red-400 dark:hover:border-red-500/50 shadow-lg shadow-red-500/10 dark:shadow-red-900/10">
                    <i class="bi bi-radioactive text-lg"></i> Notificar Error
                </button>
            </div>

            <div id="header-stats" class="bg-white/90 dark:bg-black/80 backdrop-blur-xl rounded-[2.5rem] shadow-[0_20px_50px_rgba(220,38,38,0.1)] dark:shadow-[0_20px_50px_rgba(0,0,0,0.5)] p-8 mb-8 border border-red-100 dark:border-red-900/30 hidden transition-colors duration-300">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center text-center md:text-left">
                    <div class="flex flex-col items-center md:items-start gap-1">
                        <span class="text-[10px] font-black text-red-500 dark:text-red-900 uppercase tracking-widest">Suministro Vital</span>
                        <div class="flex items-center gap-3">
                            <span class="text-red-500 dark:text-red-600 text-4xl drop-shadow-[0_0_15px_rgba(220,38,38,0.6)] dark:drop-shadow-[0_0_15px_rgba(220,38,38,1)] animate-pulse">❤️</span>
                            <span class="text-4xl font-black font-mono text-slate-800 dark:text-white"><span id="vidas-count">@ViewBag.VidasRuleta</span></span>
                        </div>
                    </div>

                    <div class="text-center bg-red-50 dark:bg-red-950/20 py-4 rounded-3xl border border-red-200 dark:border-red-900/10 shadow-inner transition-colors">
                        <span class="text-[10px] font-black text-slate-500 uppercase tracking-[0.3em] block mb-1">Score Global</span>
                        <h3 class="text-5xl font-black text-red-700 dark:text-white tracking-tighter drop-shadow-sm dark:drop-shadow-[0_0_10px_rgba(255,255,255,0.2)]">
                            <span id="score">0</span>
                        </h3>
                    </div>

                    <div class="flex flex-col items-center md:items-end gap-1">
                        <span class="text-[10px] font-black text-yellow-600 dark:text-yellow-900 uppercase tracking-widest text-right">Tiempo Crítico</span>
                        <div class="text-4xl font-black text-yellow-500 font-mono flex items-center gap-2 drop-shadow-[0_0_10px_rgba(234,179,8,0.4)]">
                            <i class="bi bi-stopwatch text-2xl text-yellow-600 dark:text-yellow-700"></i> <span id="timer-text">30</span><span class="text-xl text-yellow-600 dark:text-yellow-700">s</span>
                        </div>
                    </div>
                </div>

                <div id="barra-tiempo-container" class="w-full bg-slate-200 dark:bg-slate-900 rounded-full h-3 mt-8 overflow-hidden border border-slate-300 dark:border-slate-800 hidden shadow-inner transition-colors">
                    <div id="timer-bar" class="bg-gradient-to-r from-red-500 via-orange-400 to-yellow-400 dark:from-red-600 dark:via-orange-500 dark:to-yellow-400 h-full rounded-full transition-all ease-linear shadow-[0_0_15px_rgba(220,38,38,0.5)]" style="width: 100%; transition-duration: 1s;"></div>
                </div>
            </div>

            <div id="juego-container">
                <div id="pantalla-carga" class="text-center py-32">
                    <div class="relative inline-flex items-center justify-center">
                        <div class="w-24 h-24 border-4 border-red-200 dark:border-red-600/20 border-t-red-600 rounded-full animate-spin absolute shadow-[0_0_30px_rgba(220,38,38,0.3)]"></div>
                        <i class="bi bi-dice-5 text-red-600 text-4xl animate-pulse"></i>
                    </div>
                    <h2 class="text-2xl font-black text-red-700 tracking-[0.3em] uppercase mt-8">Sincronizando Ruleta...</h2>

                    <div class="mt-8 animate-fade-in-up">
                        <p class="text-slate-500 dark:text-slate-400 font-bold uppercase tracking-widest text-sm mb-2">Tema asignado por el destino:</p>
                        <h1 class="text-4xl md:text-5xl font-black text-slate-800 dark:text-white uppercase drop-shadow-[0_0_15px_rgba(220,38,38,0.2)] dark:drop-shadow-[0_0_15px_rgba(220,38,38,0.6)] transition-colors">
                            @ViewBag.NombreCuestionario
                        </h1>
                    </div>
                </div>

                <div id="game-card" class="bg-white/80 dark:bg-black/40 backdrop-blur-md rounded-[3rem] shadow-2xl overflow-hidden border border-slate-200 dark:border-white/5 hidden transform transition-all duration-300">
                    <div class="p-10 md:p-14 text-center relative border-b border-slate-200 dark:border-white/5 transition-colors">
                        <div class="absolute top-6 left-1/2 -translate-x-1/2 text-[10px] font-black text-red-500 dark:text-red-900 uppercase tracking-[0.5em]">Misión de Supervivencia</div>
                        <h3 id="enunciado-UI" class="text-3xl md:text-4xl font-black leading-tight text-slate-800 dark:text-slate-100 mt-4 drop-shadow-sm dark:drop-shadow-lg transition-colors">
                            Cargando datos...
                        </h3>
                    </div>

                    <div class="p-8 md:p-12">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="respuestas-container">
                        </div>
                    </div>

                    <div class="bg-slate-100 dark:bg-black/60 p-5 flex justify-between items-center px-12 border-t border-slate-200 dark:border-white/5 transition-colors">
                        <span class="text-[10px] font-black text-slate-500 uppercase">Fase <span id="current-index" class="text-red-600 text-sm">1</span></span>
                        <div class="flex gap-1.5">
                            <div class="w-2 h-2 rounded-full bg-red-500 dark:bg-red-600 animate-pulse shadow-[0_0_5px_red]"></div>
                            <div class="w-2 h-2 rounded-full bg-red-200 dark:bg-red-900"></div>
                            <div class="w-2 h-2 rounded-full bg-red-200 dark:bg-red-900"></div>
                        </div>
                        <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Amenaza: <span id="nivel-badge" class="text-slate-800 dark:text-white">--</span></span>
                    </div>
                </div>
            </div>

            <div id="gameOverModal" class="hidden fixed inset-0 bg-white/95 dark:bg-black/95 z-50 flex items-center justify-center p-4 transition-colors duration-500">
                <div class="text-center animate__animated animate__fadeIn space-y-8 max-w-lg">
                    <div class="relative inline-block">
                        <div class="absolute inset-0 bg-red-500 dark:bg-red-600 blur-[60px] dark:blur-[80px] opacity-30 animate-pulse"></div>
                        <h1 class="text-[8rem] md:text-[10rem] font-black text-red-600 leading-none tracking-tighter drop-shadow-[0_0_40px_rgba(220,38,38,0.5)] dark:drop-shadow-[0_0_40px_rgba(220,38,38,0.9)]">FIN</h1>
                    </div>

                    <div class="space-y-2">
                        <p class="text-slate-500 font-black uppercase tracking-[0.4em] text-sm italic" id="texto-destino">Has perecido en la ruleta</p>
                        <div class="text-7xl font-black text-slate-900 dark:text-white" id="final-score">0 <span class="text-xl text-red-600 dark:text-red-900 uppercase">Pts</span></div>
                    </div>

                    <form id="form-guardar-ranking" asp-action="GuardarRanking" asp-controller="Partidas" method="post" class="pt-10">
                        <input type="hidden" id="input-puntos" name="puntos" value="0" />
                        <input type="hidden" name="modoJuego" value="RULETA" />
                        <input type="hidden" name="nombreCuestionario" value="@ViewBag.NombreCuestionario" />

                        <button type="submit" class="group relative px-12 py-5 bg-red-600 text-white font-black rounded-2xl text-xl transition-all hover:bg-red-500 shadow-[0_0_40px_rgba(220,38,38,0.4)] overflow-hidden active:scale-95">
                            <span class="relative z-10 flex items-center gap-2">ACEPTAR MI DESTINO <i class="bi bi-box-arrow-right"></i></span>
                            <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform"></div>
                        </button>
                    </form>
                </div>
            </div>

            <div id="modalReporte" class="hidden fixed inset-0 bg-slate-900/60 dark:bg-black/95 z-[60] flex items-center justify-center p-4 backdrop-blur-md">
                <div class="bg-white dark:bg-slate-950 rounded-[2.5rem] shadow-2xl w-full max-w-md border border-slate-200 dark:border-red-900/50 overflow-hidden transition-colors">
                    <div class="bg-red-50 dark:bg-red-900/20 p-6 text-red-700 dark:text-red-500 border-b border-red-100 dark:border-red-900/30 flex justify-between items-center uppercase tracking-widest font-black text-xs transition-colors">
                        <span>Transmisión de Fallo</span>
                        <button onclick="cerrarModalReporte()" class="hover:text-red-900 dark:hover:text-white transition-colors text-2xl">&times;</button>
                    </div>
                    <div class="p-8 space-y-6">
                        <select id="motivoReporte" class="w-full p-4 bg-slate-50 dark:bg-black border border-slate-200 dark:border-white/5 text-slate-700 dark:text-slate-300 rounded-2xl focus:border-red-500 dark:focus:border-red-600 outline-none font-bold uppercase text-[10px] tracking-widest transition-colors">
                            <option value="Respuesta incorrecta">Dato Erróneo</option>
                            <option value="Falta de ortografía">Error Tipográfico</option>
                            <option value="Contenido ofensivo">Contenido Inadecuado</option>
                            <option value="Otro">Otros Errores</option>
                        </select>
                        <textarea id="comentarioReporte" rows="3" class="w-full p-4 bg-slate-50 dark:bg-black border border-slate-200 dark:border-white/5 text-slate-700 dark:text-slate-300 rounded-2xl focus:border-red-500 dark:focus:border-red-600 outline-none placeholder-slate-400 dark:placeholder-slate-800 text-sm font-medium transition-colors" placeholder="Describe la anomalía..."></textarea>
                        <button onclick="enviarReporte()" id="btnEnviarReporte" class="w-full bg-red-600 dark:bg-red-700 text-white font-black py-4 rounded-2xl hover:bg-red-500 dark:hover:bg-red-600 transition-all uppercase tracking-widest text-xs shadow-lg shadow-red-500/20 dark:shadow-red-900/20">
                            Enviar Transmisión
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        let idPreguntaActualReporte = 0;

        window.abrirModalReporte = function() {
            if(idPreguntaActualReporte > 0) {
                document.getElementById('motivoReporte').value = 'Respuesta incorrecta';
                document.getElementById('comentarioReporte').value = '';
                document.getElementById('modalReporte').classList.remove('hidden');
            }
        };

        window.cerrarModalReporte = function () {
            document.getElementById('modalReporte').classList.add('hidden');
        };

        window.enviarReporte = async function() {
            const btn = document.getElementById('btnEnviarReporte');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-arrow-repeat animate-spin"></i> Enviando...';

            const isDark = document.documentElement.classList.contains('dark');
            const bgColor = isDark ? '#0f172a' : '#ffffff';
            const textColor = isDark ? '#f8fafc' : '#1e293b';

            try {
                const formData = new FormData();
                formData.append('idPregunta', idPreguntaActualReporte);
                formData.append('motivo', document.getElementById('motivoReporte').value);
                formData.append('comentario', document.getElementById('comentarioReporte').value);

                const response = await fetch('/Social/ReportarPregunta', { method: 'POST', body: formData });
                const data = await response.json();

                if(data.success) {
                    window.cerrarModalReporte();
                    Swal.fire({
                        title: '¡Anomalía Reportada!',
                        text: 'Hemos recibido tu transmisión. Lo revisaremos enseguida.',
                        icon: 'success',
                        background: bgColor,
                        color: textColor,
                        confirmButtonColor: '#10b981',
                        confirmButtonText: '<i class="bi bi-check-lg"></i> Entendido'
                    });
                } else {
                    Swal.fire({
                        title: 'Error en la transmisión',
                        text: data.message || "No se pudo enviar el reporte.",
                        icon: 'error',
                        background: bgColor,
                        color: textColor,
                        confirmButtonColor: '#e11d48'
                    });
                }
            } catch (error) {
                Swal.fire({
                    title: 'Enlace perdido',
                    text: 'Hubo un error de conexión con el centro de mando.',
                    icon: 'warning',
                    background: bgColor,
                    color: textColor,
                    confirmButtonColor: '#f59e0b'
                });
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Enviar Transmisión';
            }
        };

        document.addEventListener("DOMContentLoaded", () => {
            const sonidoCirco = new Audio('/sounds/sonido_circo.mp3');
            sonidoCirco.volume = 0.6;
            const soundAcierto = new Audio('/sounds/acierto.mp3');
            const soundError = new Audio('/sounds/fallo.mp3');

            soundAcierto.volume = 0.7;
            soundError.volume = 0.7;

            const idsPreguntas = @Html.Raw(Json.Serialize(Model));
            let totalPreguntas = idsPreguntas.length;
            let indexActual = 0;
            let score = 0;
            let vidas = @ViewBag.VidasRuleta;

            let tiempoBase = 30;
            let tiempoRestante = tiempoBase;
            let timerInterval = null;

            const gameCard = document.getElementById("game-card");
            const headerStats = document.getElementById("header-stats");
            const barraTiempo = document.getElementById("barra-tiempo-container");
            const pantallaCarga = document.getElementById("pantalla-carga");

            async function cargarPreguntaActual() {
                if (indexActual >= totalPreguntas) {
                    mostrarGameOver();
                    return;
                }

                if (indexActual === 0) {
                    pantallaCarga.classList.remove("hidden");
                    gameCard.classList.add("hidden");
                } else {
                    gameCard.style.opacity = 0.5;
                    gameCard.style.transform = "translateY(10px)";
                }

                idPreguntaActualReporte = idsPreguntas[indexActual];

                try {
                    const response = await fetch('/Datos/ObtenerPreguntaPorId?idPregunta=' + idPreguntaActualReporte);
                    const p = await response.json();

                    if (p.success) {
                        document.getElementById("enunciado-UI").innerText = p.enunciado;
                        document.getElementById("current-index").innerText = indexActual + 1;
                        document.getElementById("nivel-badge").innerText = p.nivel;

                        let opciones = [
                            { texto: p.opcionCorrecta, correcta: true },
                            { texto: p.opcionIncorrecta1, correcta: false },
                            { texto: p.opcionIncorrecta2, correcta: false },
                            { texto: p.opcionIncorrecta3, correcta: false }
                        ].sort(() => Math.random() - 0.5);

                        const container = document.getElementById("respuestas-container");
                        container.innerHTML = "";

                        const btnClasses = "btn-respuesta group relative w-full p-6 rounded-2xl font-black text-lg text-slate-700 dark:text-slate-400 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 shadow-sm dark:shadow-lg hover:border-red-500 dark:hover:border-red-600 hover:text-red-700 dark:hover:text-white transition-all overflow-hidden active:scale-95";

                        opciones.forEach(r => {
                            const textoSeguro = r.texto ? r.texto.replace(/'/g, "&#39;") : "";
                            const esCorrectaAttr = r.correcta ? "true" : "false";

                            container.innerHTML += `
                                <button type="button" class="${btnClasses}" data-correcta="${esCorrectaAttr}" data-nivel="${p.nivel}">
                                    <div class="absolute inset-0 bg-gradient-to-r from-red-600/5 dark:from-red-600/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                    <span class="relative z-10">${textoSeguro}</span>
                                </button>
                            `;
                        });

                        pantallaCarga.classList.add("hidden");
                        headerStats.classList.remove("hidden");
                        barraTiempo.classList.remove("hidden");
                        gameCard.classList.remove("hidden");

                        setTimeout(() => {
                            gameCard.style.opacity = 1;
                            gameCard.style.transform = "translateY(0)";
                        }, 50);

                        iniciarReloj();
                    }
                } catch (error) {
                    console.error(error);
                }
            }

            function iniciarReloj() {
                clearInterval(timerInterval);

                if (indexActual > 0 && indexActual % 10 === 0) {
                    tiempoBase = Math.max(5, tiempoBase - 5);
                    document.body.style.backgroundColor = document.documentElement.classList.contains("dark") ? "#450a0a" : "#fee2e2";
                    setTimeout(() => document.body.style.backgroundColor = "", 100);
                }

                tiempoRestante = tiempoBase;
                actualizarUI_Reloj();

                timerInterval = setInterval(() => {
                    tiempoRestante--;
                    actualizarUI_Reloj();

                    if (tiempoRestante <= 0) {
                        clearInterval(timerInterval);
                        const botones = document.querySelectorAll(".btn-respuesta");
                        botones.forEach(b => b.disabled = true);

                        try {
                            soundError.currentTime = 0;
                            soundError.play().catch(e => {});
                        } catch(e) {}

                        manejarFallo(botones);
                    }
                }, 1000);
            }

            function actualizarUI_Reloj() {
                const timerText = document.getElementById("timer-text");
                timerText.innerText = tiempoRestante;
                let porcentaje = (tiempoRestante / tiempoBase) * 100;
                const barra = document.getElementById("timer-bar");
                barra.style.width = porcentaje + "%";

                if (porcentaje <= 25) {
                    timerText.classList.add("text-red-500", "animate-ping");
                } else {
                    timerText.classList.remove("text-red-500", "animate-ping");
                }
            }

            document.getElementById("respuestas-container").addEventListener("click", (e) => {
                const boton = e.target.closest(".btn-respuesta");
                if (!boton) return;

                clearInterval(timerInterval);
                const botones = document.querySelectorAll(".btn-respuesta");
                botones.forEach(b => b.disabled = true);

                const esCorrecta = boton.getAttribute("data-correcta") === "true";
                const nivel = parseInt(boton.getAttribute("data-nivel"));

                if (esCorrecta) {
                    try {
                        soundAcierto.currentTime = 0;
                        soundAcierto.play().catch(e => {});
                    } catch(e) {}

                    boton.className = "btn-respuesta w-full p-6 rounded-2xl font-black text-xl text-emerald-800 dark:text-white bg-emerald-100 dark:bg-emerald-600/20 border-2 border-emerald-400 dark:border-emerald-500 shadow-[0_0_30px_rgba(16,185,129,0.3)] transition-all scale-105";
                    score += (nivel * 10);
                    document.getElementById("score").innerText = score;
                    setTimeout(() => { indexActual++; cargarPreguntaActual(); }, 1200);
                } else {
                    try {
                        soundError.currentTime = 0;
                        soundError.play().catch(e => {});
                    } catch(e) {}

                    boton.className = "btn-respuesta w-full p-6 rounded-2xl font-black text-xl text-red-800 dark:text-white bg-red-100 dark:bg-red-600/20 border-2 border-red-400 dark:border-red-500 shadow-[0_0_30px_rgba(220,38,38,0.3)] transition-all";
                    manejarFallo(botones);
                }
            });

            function manejarFallo(botones) {
                clearInterval(timerInterval);
                vidas--;
                document.getElementById("vidas-count").innerText = vidas;

                if (botones) {
                    botones.forEach(b => {
                        if (b.getAttribute('data-correcta') === 'true') {
                            b.className = "btn-respuesta w-full p-6 rounded-2xl font-black text-xl text-emerald-800 dark:text-white border-2 border-emerald-400 dark:border-emerald-500/50 bg-emerald-50 dark:bg-emerald-950/20 transition-all shadow-[0_0_15px_rgba(16,185,129,0.2)]";
                        }
                    });
                }

                if (vidas <= 0) {
                    setTimeout(mostrarGameOver, 1500);
                } else {
                    setTimeout(() => { indexActual++; cargarPreguntaActual(); }, 2000);
                }
            }

            function mostrarGameOver() {
                clearInterval(timerInterval);
                document.getElementById("final-score").innerHTML = `${score} <span class="text-2xl text-red-600">pts</span>`;
                document.getElementById("input-puntos").value = score;

                if (vidas <= 0) {
                    try {
                        sonidoCirco.currentTime = 0;
                        sonidoCirco.play().catch(e => {});
                    } catch(e) {}
                } else {
                    document.getElementById("texto-destino").innerText = "¡Has sobrevivido a la ruleta!";
                    document.getElementById("texto-destino").classList.replace("text-slate-500", "text-emerald-500");
                }

                document.getElementById('gameOverModal').classList.remove('hidden');
            }

            setTimeout(() => {
                cargarPreguntaActual();
            }, 2000);
        });
    </script>
}