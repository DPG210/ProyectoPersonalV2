@model List<string>
@using System.Security.Claims

@* --- ENVOLTORIO PRINCIPAL CON SOPORTE DARK MODE --- *@
<div class="h-[100dvh] w-full overflow-hidden bg-slate-50 dark:bg-slate-950 font-sans text-slate-800 dark:text-slate-200 transition-colors duration-500 flex relative">

    @* --- CUERPO PRINCIPAL --- *@
    <main class="flex-1 flex flex-col h-full relative z-10 p-4 lg:p-6" id="main-content">

        @* Botón Flotante Ranking *@
        <button onclick="toggleDrawer()" id="btn-open-ranking" class="fixed top-8 right-8 z-40 bg-gradient-to-r from-amber-500 to-orange-500 text-white p-4 rounded-full shadow-lg shadow-orange-500/30 hover:scale-110 transition-transform flex items-center gap-2 group">
            <i class="bi bi-trophy-fill text-xl group-hover:animate-bounce"></i>
            <span class="text-xs font-black uppercase tracking-widest hidden md:block pr-2">Ranking</span>
        </button>

        <div class="max-w-6xl mx-auto w-full h-full flex flex-col min-h-0 gap-5">

            @* --- TOP BAR (HUD): LOGO + VIDAS + CONTROLES --- *@
            <div class="flex flex-col lg:flex-row justify-between items-center shrink-0 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl p-3 md:p-4 rounded-[2.5rem] border border-slate-200/60 dark:border-slate-800 shadow-sm gap-4 transition-colors duration-300">

                @* 1. LOGO DE LA APP *@
                <div class="flex items-center pl-2 md:pl-4 shrink-0">
                        <img src="~/images/logo/logo.png"
                             class="h-12 md:h-14 w-auto object-contain drop-shadow-[0_10px_15px_rgba(79,70,229,0.25)] dark:drop-shadow-[0_10px_15px_rgba(79,70,229,0.5)]"
                             alt="Trivial Logo" />
                </div>

                @* 2. INDICADOR DE VIDAS (CENTRO) *@
                <div class="flex-grow flex justify-center w-full lg:w-auto order-last lg:order-none">
                    @if (ViewBag.Corazones != null)
                    {
                        int corazonesActuales = (int)ViewBag.Corazones;
                        <div class="flex items-center gap-4 bg-rose-50 dark:bg-rose-900/20 px-6 py-3 rounded-[2rem] border border-rose-100 dark:border-rose-800/50 shadow-inner transition-colors duration-300">
                            <span class="text-[10px] font-black text-rose-500 dark:text-rose-400 uppercase tracking-widest hidden sm:block">Suministro Vital</span>
                            <div class="flex gap-1.5">
                                @for (int i = 0; i < 5; i++)
                                {
                                    <span class="text-2xl @(i < corazonesActuales ? "drop-shadow-md transform hover:scale-125 transition-transform cursor-pointer" : "grayscale opacity-20 dark:opacity-30")">@(i < corazonesActuales ? "❤️" : "🤍")</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                @* 3. CONTROLES DE USUARIO (DERECHA) *@
                <div class="flex items-center gap-3 shrink-0 pr-1 lg:pr-[100px] xl:pr-2">

                    @* Alerta de vidas (si aplica) *@
                    @if (TempData["ErrorVidas"] != null)
                    {
                        <div class="hidden md:flex bg-rose-500 text-white px-4 py-2.5 rounded-2xl shadow-md text-xs font-bold animate__animated animate__shakeX items-center gap-2">
                            <span>💔 @TempData["ErrorVidas"]</span>
                        </div>
                    }

                    @* Botón Admin *@
                    @if (User.IsInRole("ADMIN") || User.IsInRole("Admin"))
                    {
                        <a asp-controller="Social" asp-action="BuzonReportes" class="relative bg-rose-50 hover:bg-rose-100 dark:bg-rose-900/20 dark:hover:bg-rose-900/40 text-rose-600 dark:text-rose-400 font-black px-4 py-2.5 rounded-2xl border border-rose-200 dark:border-rose-800 transition-colors flex items-center gap-2 text-[10px] uppercase tracking-widest shadow-sm">
                            <i class="bi bi-shield-lock-fill text-base"></i> <span class="hidden sm:inline">Admin</span>
                            <span class="absolute -top-2 -right-2 bg-red-600 text-white text-[9px] font-black px-2 py-0.5 rounded-full animate-pulse border-2 border-white dark:border-slate-900 shadow-sm">@ViewBag.NumReportes</span>
                        </a>
                    }

                    @* Botón Buscar Salas *@
                    <a asp-controller="SalasMultijugador" asp-action="BuscadorSalasPublicas" class="bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-600 hover:text-white dark:hover:bg-indigo-500 dark:hover:text-white font-black px-5 py-2.5 rounded-2xl shadow-sm border border-indigo-100 dark:border-indigo-800 transition-colors flex items-center gap-2 text-[10px] uppercase tracking-widest">
                        <i class="bi bi-radar text-base animate-[spin_4s_linear_infinite]"></i> <span class="hidden sm:inline">Salas Públicas</span>
                    </a>

                    @* Botón Perfil (Gamer Tag) *@
                    <a asp-controller="Managed" asp-action="Perfil" class="group flex items-center gap-3 bg-slate-50 dark:bg-slate-800/50 hover:bg-white dark:hover:bg-slate-700 p-1.5 pr-5 rounded-[2rem] shadow-inner hover:shadow-md border border-slate-200 dark:border-slate-600 transition-all cursor-pointer ml-2">
                        <div class="relative">
                            <img src="~/images/avatares/@(User.FindFirst("Avatar")?.Value ?? "avatar1.png")" alt="Perfil" class="w-10 h-10 rounded-full object-cover border-2 border-white dark:border-slate-700 shadow-sm group-hover:scale-105 transition-transform" />
                            <div class="absolute bottom-0 right-0 w-3 h-3 bg-emerald-500 border-2 border-white dark:border-slate-800 rounded-full shadow-sm"></div>
                            <span class="absolute -top-2 -right-2 bg-blue-600 text-white text-[9px] font-black px-2 py-0.5 rounded-full animate-pulse border-2 border-white dark:border-slate-900 shadow-sm">@ViewBag.NumSolicitudes</span>
                        </div>
                        <div class="hidden sm:flex flex-col justify-center min-w-0">
                            <span class="text-sm font-black text-slate-700 dark:text-slate-200 leading-none group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors truncate">@User.Identity.Name</span>
                        </div>
                    </a>

                    @* Logout *@
                    <a asp-controller="Managed" asp-action="Logout" title="Cerrar Sesión" class="bg-slate-100 dark:bg-slate-800 text-slate-400 dark:text-slate-400 hover:bg-rose-500 hover:text-white dark:hover:bg-rose-600 dark:hover:text-white dark:hover:border-rose-500 hover:shadow-lg hover:shadow-rose-500/30 w-10 h-10 rounded-full shadow-sm border border-slate-200 dark:border-slate-700 transition-all flex items-center justify-center group ml-1">
                        <i class="bi bi-power text-lg group-hover:scale-110 transition-transform"></i>
                    </a>
                </div>
            </div>
            @if (ViewBag.Invitaciones != null)
            {
                <div class="w-full animate__animated animate__fadeInDown shrink-0 mb-6 bg-emerald-50/40 dark:bg-emerald-900/10 p-5 rounded-[2.5rem] border border-emerald-100 dark:border-emerald-800/50">

                    @* HEADER / BOTÓN DESPLEGABLE *@
                    <button onclick="toggleBuzonInvitaciones()" class="w-full flex items-center justify-between group cursor-pointer outline-none transition-opacity hover:opacity-80">
                        <h3 class="text-sm font-black text-emerald-600 dark:text-emerald-400 uppercase tracking-[0.2em] flex items-center gap-3 pl-2">
                            <i class="bi bi-radar text-xl animate-pulse"></i>
                            Partidas Entrantes (@ViewBag.Invitaciones.Count)
                        </h3>
                        <div class="w-8 h-8 bg-white dark:bg-slate-800 rounded-full flex items-center justify-center text-emerald-600 dark:text-emerald-400 shadow-sm border border-emerald-100 dark:border-emerald-800 group-hover:bg-emerald-600 group-hover:text-white dark:group-hover:bg-emerald-500 transition-colors">
                            <i id="icono-buzon" class="bi bi-chevron-up transition-transform duration-300"></i>
                        </div>
                    </button>

                    @* GRID DE TARJETAS (El div que se oculta/muestra) *@
                    <div id="grid-invitaciones" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-5 transition-all origin-top">
                        @foreach (InvitacionPartida inv in @ViewBag.Invitaciones)
                        {
                            <div class="bg-gradient-to-br from-white to-emerald-50/50 dark:from-slate-900 dark:to-emerald-900/10 p-5 rounded-[2rem] border border-emerald-100 dark:border-emerald-900/30 shadow-lg shadow-emerald-100/40 dark:shadow-black/20 flex flex-col justify-between group hover:-translate-y-1 transition-transform">

                                <div class="flex items-start gap-4 mb-4">
                                    <div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/40 rounded-xl flex items-center justify-center text-2xl text-emerald-600 dark:text-emerald-400 shadow-inner shrink-0">
                                        <i class="bi bi-joystick"></i>
                                    </div>
                                    <div class="overflow-hidden">
                                        <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Desafío de</p>
                                        <h4 class="font-black text-slate-800 dark:text-white text-lg truncate leading-tight">@inv.NombreEmisor</h4>
                                        <p class="text-xs font-bold text-indigo-500 dark:text-indigo-400 truncate mt-1" title="@inv.TituloCuestionario">
                                            <i class="bi bi-bookmark-star-fill"></i> @inv.TituloCuestionario
                                        </p>
                                    </div>
                                </div>

                                <div class="flex gap-2 w-full mt-auto">
                                    @* Botón Rechazar *@
                                    <form asp-controller="Social" asp-action="ResponderInvitacionPartida" method="post" class="flex-grow">
                                        <input type="hidden" name="codigoSala" value="@inv.CodigoSala" />
                                        <input type="hidden" name="aceptar" value="false" />
                                        <button type="submit" class="w-full bg-white dark:bg-slate-800 text-rose-500 hover:bg-rose-500 hover:text-white dark:hover:bg-rose-600 dark:hover:text-white font-black py-3 rounded-xl border border-rose-100 dark:border-slate-700 hover:border-transparent transition-all shadow-sm flex items-center justify-center gap-1 text-xs tracking-widest">
                                            <i class="bi bi-x-lg"></i> IGNORAR
                                        </button>
                                    </form>

                                    @* Botón Aceptar (Unirse) *@
                                    <form asp-controller="Social" asp-action="ResponderInvitacionPartida" method="post" class="flex-grow">
                                        <input type="hidden" name="codigoSala" value="@inv.CodigoSala" />
                                        <input type="hidden" name="aceptar" value="true" />
                                        <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-black py-3 rounded-xl shadow-md hover:shadow-lg transition-all flex items-center justify-center gap-2 text-xs tracking-widest active:scale-95">
                                            UNIRSE <i class="bi bi-rocket-takeoff-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            @* --- DASHBOARD CONFIGURADOR (BENTO BOX) --- *@
            <div id="game-card" class="bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl rounded-[2.5rem] shadow-2xl shadow-indigo-100/40 dark:shadow-black/40 border border-slate-100 dark:border-slate-800 p-6 md:p-8 relative transition-all duration-300 flex-1 flex flex-col min-h-0 overflow-y-auto custom-scrollbar">

                <div class="grid grid-cols-1 md:grid-cols-12 gap-5 lg:gap-6 flex-grow">

                    @* PASO 1: MODO DE JUEGO *@
                    <div class="md:col-span-12 bg-amber-50 dark:bg-amber-900/10 rounded-[2rem] p-5 md:p-6 border-2 border-amber-100/50 dark:border-amber-900/30 shrink-0 animate__animated animate__fadeInUp animate__faster transition-colors duration-300">
                        <div class="flex items-center gap-3 mb-5">
                            <div class="bg-amber-500 text-white w-10 h-10 rounded-[1rem] flex items-center justify-center text-xl shadow-md">🕹️</div>
                            <h2 class="text-xl font-black text-amber-950 dark:text-amber-200 leading-none">1. ¿A qué vamos a jugar?</h2>
                        </div>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                            <button type="button" onclick="setModo('quizz', this)" class="btn-modo group relative p-5 rounded-3xl border-2 border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:border-amber-500 hover:bg-amber-50 dark:hover:border-amber-500 dark:hover:bg-amber-900/20 transition-all text-center shadow-sm">
                                <span class="block text-4xl mb-2 transition-transform group-hover:scale-110 drop-shadow-sm">⏱️</span>
                                <span class="block text-[11px] font-black uppercase tracking-widest text-slate-700 dark:text-slate-300">Quizz</span>
                            </button>
                            <button type="button" onclick="setModo('trivial', this)" class="btn-modo group relative p-5 rounded-3xl border-2 border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:border-indigo-500 hover:bg-indigo-50 dark:hover:border-indigo-500 dark:hover:bg-indigo-900/20 transition-all text-center shadow-sm">
                                <span class="block text-4xl mb-2 transition-transform group-hover:scale-110 drop-shadow-sm">🧠</span>
                                <span class="block text-[11px] font-black uppercase tracking-widest text-slate-700 dark:text-slate-300">Trivial</span>
                            </button>
                            <button type="button" onclick="setModo('supervivencia', this)" class="btn-modo group relative p-5 rounded-3xl border-2 border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:border-emerald-500 hover:bg-emerald-50 dark:hover:border-emerald-500 dark:hover:bg-emerald-900/20 transition-all text-center shadow-sm">
                                <span class="block text-4xl mb-2 transition-transform group-hover:scale-110 drop-shadow-sm">🛡️</span>
                                <span class="block text-[11px] font-black uppercase tracking-widest text-slate-700 dark:text-slate-300">Survival</span>
                            </button>
                            <button type="button" onclick="setModo('ruleta', this)" class="btn-modo group relative p-5 rounded-3xl border-2 border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:border-red-500 hover:bg-red-50 dark:hover:border-red-500 dark:hover:bg-red-900/20 transition-all text-center shadow-sm">
                                <span class="block text-4xl mb-2 transition-transform group-hover:scale-110 drop-shadow-sm">💀</span>
                                <span class="block text-[11px] font-black uppercase tracking-widest text-slate-700 dark:text-slate-300">Ruleta</span>
                            </button>
                        </div>
                    </div>

                    @* PANEL INFERIOR *@
                    <div id="panel-configuracion" class="md:col-span-12 grid grid-cols-1 md:grid-cols-12 gap-5 opacity-40 grayscale pointer-events-none transition-all duration-300">

                        @* PASO 2: LA MISIÓN *@
                        <div id="bloque-tematica" class="md:col-span-12 bg-indigo-50/50 dark:bg-indigo-900/10 rounded-[2rem] p-6 border-2 border-indigo-100/50 dark:border-indigo-900/30 transition-colors duration-300">
                            <div class="flex items-center gap-3 mb-5">
                                <div class="bg-indigo-500 text-white w-9 h-9 rounded-xl flex items-center justify-center text-lg shadow-sm">🎯</div>
                                <h2 class="text-xl font-black text-indigo-950 dark:text-indigo-200 leading-none">2. Elige tu misión</h2>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div class="space-y-2">
                                    <label class="block text-[11px] font-black text-indigo-800 dark:text-indigo-400 uppercase tracking-widest ml-2">Categoría</label>
                                    <select id="select-categoria" class="w-full bg-white dark:bg-slate-800 border-2 border-transparent dark:border-slate-700 focus:border-indigo-500 dark:focus:border-indigo-500 rounded-2xl px-5 py-4 font-bold text-slate-800 dark:text-slate-200 shadow-sm outline-none text-sm transition-all cursor-pointer appearance-none">
                                        <option value="">🔮 Selecciona una categoría...</option>
                                        @foreach (string cat in Model)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                    </select>
                                </div>
                                <div class="space-y-2">
                                    <label class="block text-[11px] font-black text-indigo-800 dark:text-indigo-400 uppercase tracking-widest ml-2">Tema Específico</label>
                                    <select id="select-cuestionario" class="w-full bg-white dark:bg-slate-800 border-2 border-transparent dark:border-slate-700 focus:border-indigo-500 dark:focus:border-indigo-500 rounded-2xl px-5 py-4 font-bold text-slate-800 dark:text-slate-200 shadow-sm outline-none disabled:opacity-50 disabled:bg-slate-100 dark:disabled:bg-slate-900 text-sm transition-all cursor-pointer appearance-none" disabled>
                                        <option value="">Esperando categoría...</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        @* PASO 3: REGLAS Y SOCIAL *@
                        <div class="md:col-span-7 grid grid-cols-1 sm:grid-cols-3 gap-4 self-start">
                            <div id="bloque-nivel" class="bg-emerald-50 dark:bg-emerald-900/10 rounded-[2rem] p-5 border-2 border-emerald-100/50 dark:border-emerald-900/30 flex flex-col justify-between transition-colors duration-300">
                                <label class="text-[11px] font-black text-emerald-800 dark:text-emerald-400 uppercase tracking-widest mb-3"><i class="bi bi-bar-chart-steps text-base"></i> Dificultad</label>
                                <select id="select-nivel" class="w-full bg-white/80 dark:bg-slate-800 border-2 border-white dark:border-slate-700 focus:border-emerald-400 dark:focus:border-emerald-500 rounded-xl px-3 py-3 text-slate-800 dark:text-slate-200 text-sm font-bold shadow-sm outline-none cursor-pointer appearance-none">
                                    <option value="0">Mixta</option>
                                    <option value="1">🟢 Fácil</option>
                                    <option value="2">🟡 Media</option>
                                    <option value="3">🟠 Difícil</option>
                                    <option value="4">🔴 Extrema</option>
                                </select>
                            </div>
                            <div id="bloque-cantidad" class="bg-sky-50 dark:bg-sky-900/10 rounded-[2rem] p-5 border-2 border-sky-100/50 dark:border-sky-900/30 flex flex-col justify-between transition-colors duration-300">
                                <label class="text-[11px] font-black text-sky-800 dark:text-sky-400 uppercase tracking-widest mb-3"><i class="bi bi-list-ol text-base"></i> Preguntas</label>
                                <select id="select-cantidad" class="w-full bg-white/80 dark:bg-slate-800 border-2 border-white dark:border-slate-700 focus:border-sky-400 dark:focus:border-sky-500 rounded-xl px-3 py-3 text-slate-800 dark:text-slate-200 text-sm font-bold shadow-sm outline-none cursor-pointer appearance-none">
                                    <option value="10">10</option>
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                    <option value="0">Todas</option>
                                </select>
                            </div>
                            <div id="bloque-tiempo" class="bg-rose-50 dark:bg-rose-900/10 rounded-[2rem] p-5 border-2 border-rose-100/50 dark:border-rose-900/30 flex flex-col justify-between transition-colors duration-300">
                                <label class="text-[11px] font-black text-rose-800 dark:text-rose-400 uppercase tracking-widest mb-3"><i class="bi bi-stopwatch text-base"></i> Tiempo</label>
                                <select id="select-tiempo" class="w-full bg-white/80 dark:bg-slate-800 border-2 border-white dark:border-slate-700 focus:border-rose-400 dark:focus:border-rose-500 rounded-xl px-3 py-3 text-slate-800 dark:text-slate-200 text-sm font-bold shadow-sm outline-none cursor-pointer appearance-none">
                                    <option value="10">⚡ 10s</option>
                                    <option value="30" selected>⏱️ 30s</option>
                                    <option value="60">☕ 60s</option>
                                </select>
                            </div>
                        </div>

                        <div class="md:col-span-5 bg-purple-50 dark:bg-purple-900/10 rounded-[2rem] p-6 border-2 border-purple-100/50 dark:border-purple-900/30 flex flex-col self-start h-full transition-colors duration-300" id="bloque-social">
                            <div class="flex items-center gap-3 mb-4">
                                <div class="bg-purple-500 text-white w-8 h-8 rounded-lg flex items-center justify-center shadow-sm">👥</div>
                                <h2 class="text-xs font-black text-purple-950 dark:text-purple-200 uppercase tracking-widest">3. Config. Social</h2>
                            </div>
                            <div class="space-y-4 flex-grow">
                                <select id="select-modo" class="w-full bg-white dark:bg-slate-800 border-2 border-purple-100 dark:border-slate-700 focus:border-purple-400 dark:focus:border-purple-500 rounded-xl px-4 py-3 text-slate-800 dark:text-slate-200 text-sm font-bold shadow-sm outline-none cursor-pointer appearance-none">
                                    <option value="solo">👤 Jugar en Solitario</option>
                                    <option value="multi">⚔️ Duelo Multijugador</option>
                                </select>
                                <div id="div-social-extras" class="hidden space-y-4 animate__animated animate__fadeIn animate__faster">
                                    <select id="select-publico" class="w-full bg-white dark:bg-slate-800 border-2 border-purple-100 dark:border-slate-700 focus:border-purple-400 dark:focus:border-purple-500 rounded-xl px-4 py-3 text-slate-800 dark:text-slate-200 text-sm font-bold shadow-sm outline-none cursor-pointer appearance-none">
                                        <option value="true">🌍 Sala Pública (Recomendado)</option>
                                        <option value="false">🔒 Sala Privada (Solo invitados)</option>
                                    </select>
                                    <select id="select-capacidad" class="w-full bg-purple-100 dark:bg-purple-900/40 border-2 border-purple-200 dark:border-purple-800 focus:border-purple-500 dark:focus:border-purple-400 rounded-xl px-4 py-3 text-purple-900 dark:text-purple-200 text-sm font-black shadow-inner outline-none cursor-pointer appearance-none">
                                        <option value="2">Límite: 2 Jugadores</option>
                                        <option value="4" selected>Límite: 4 Jugadores</option>
                                        <option value="8">Límite: 8 Jugadores</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                    </div>

                    @* BOTÓN DE ACCIÓN GIGANTE *@
                    <div class="md:col-span-12 mt-4">
                        <button id="btn-comenzar" class="w-full bg-slate-200 dark:bg-slate-800 text-slate-400 dark:text-slate-500 font-black py-6 rounded-[2rem] shadow-sm disabled:opacity-50 disabled:cursor-not-allowed transition-all duration-300 flex items-center justify-center gap-4 group text-2xl" disabled>
                            <span>¡INICIAR DESPLIEGUE!</span>
                            <i class="bi bi-rocket-takeoff-fill text-3xl group-hover:animate-bounce"></i>
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </main>

    @* --- DRAWER (PANEL LATERAL OCULTO) PARA EL RANKING --- *@
    <div id="ranking-drawer" class="fixed inset-y-0 right-0 z-50 w-full md:w-96 bg-white dark:bg-slate-900 shadow-[0_0_40px_rgba(0,0,0,0.3)] transform translate-x-full transition-transform duration-500 ease-in-out flex flex-col border-l border-slate-200 dark:border-slate-800">

        @* Header Drawer *@
        <div class="p-6 flex justify-between items-center border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/50 shrink-0">
            <h2 class="text-xl font-black text-indigo-600 dark:text-indigo-400 flex items-center gap-3"><i class="bi bi-trophy-fill text-2xl"></i> Salón de la Fama</h2>
            <button onclick="toggleDrawer()" class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 w-10 h-10 rounded-full flex items-center justify-center hover:bg-rose-500 hover:text-white dark:hover:bg-rose-600 dark:hover:text-white dark:hover:border-transparent transition-colors shadow-sm">
                <i class="bi bi-x-lg font-black text-lg"></i>
            </button>
        </div>

        @* Contenido del Ranking *@
        <div class="flex-grow flex flex-col min-h-0">
            @* Pestañas *@
            <div class="flex shrink-0 p-4 bg-slate-50 dark:bg-slate-900 border-b border-slate-100 dark:border-slate-800 gap-2">
                <button onclick="switchRanking('supervivencia')" id="tab-sv" class="flex-1 py-3 text-[11px] font-black uppercase tracking-widest rounded-2xl bg-amber-500 text-white shadow-md transition-all">🛡️ Survival</button>
                <button onclick="switchRanking('ruleta')" id="tab-ruleta" class="flex-1 py-3 text-[11px] font-black uppercase tracking-widest rounded-2xl text-slate-400 dark:text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-800 transition-all bg-transparent border border-slate-200 dark:border-slate-700">💀 Ruleta</button>
            </div>

            @* Filtros *@
            <div class="px-5 py-4 bg-slate-50 dark:bg-slate-800/30 shrink-0 border-b border-slate-100 dark:border-slate-800">
                <div id="filter-sv-container">
                    <select id="filter-sv-cat" class="w-full bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 rounded-2xl px-4 py-3 text-sm font-bold text-slate-800 dark:text-slate-200 outline-none focus:border-amber-400 shadow-sm cursor-pointer appearance-none">
                        <option value="">🌎 Todas las Categorías</option>
                        @foreach (string cat in Model)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>
                <div id="filter-ruleta-container" class="hidden">
                    <select id="order-ruleta" class="w-full bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 rounded-2xl px-4 py-3 text-sm font-bold text-slate-800 dark:text-slate-200 outline-none focus:border-red-400 shadow-sm cursor-pointer appearance-none">
                        <option value="desc">📈 Mayor a Menor Puntuación</option>
                        <option value="asc">📉 Menor a Mayor Puntuación</option>
                    </select>
                </div>
            </div>

            @* Lista Ranking *@
            <div id="ranking-body" class="flex-1 overflow-y-auto p-5 space-y-3 custom-scrollbar bg-white dark:bg-slate-900">
                @* AJAX *@
            </div>
        </div>
    </div>

    @* Overlay negro oscuro detrás del Drawer *@
    <div id="drawer-overlay" onclick="toggleDrawer()" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-40 opacity-0 pointer-events-none transition-opacity duration-500"></div>

</div>

<style>
    /* Ocultar scrollbar global para efecto Inmersivo */
    body {
        overflow: hidden;
    }

    /* Scrollbar sutil para el bento box y el ranking */
    .custom-scrollbar::-webkit-scrollbar {
        width: 5px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }

    .dark .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #475569;
    }

    /* Estilos para los botones de modo SELECCIONADOS */
    .btn-modo.selected {
        border-color: currentColor;
        background: rgba(0,0,0,0.02);
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.08);
        transform: scale(0.95);
    }

    .dark .btn-modo.selected {
        background: rgba(255,255,255,0.05);
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.3);
    }

    /* Quitar flecha fea de los selects en modo oscuro/claro forzando custom arrow */
    select {
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 1rem center;
        background-size: 1em;
    }

    .dark select {
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2394a3b8' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    }

    /* Skeleton Loader Animation */
    .skeleton-item {
        animation: pulse 1.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: .5;
        }
    }
</style>

<script>
    let modoJuegoSeleccionado = "";
    let currentRankingMode = 'supervivencia';

    // --- DRAWER (RANKING LATERAL) ---
    function toggleDrawer() {
        const drawer = document.getElementById('ranking-drawer');
        const overlay = document.getElementById('drawer-overlay');
        const btnOpen = document.getElementById('btn-open-ranking');

        drawer.classList.toggle('translate-x-full');

        if(drawer.classList.contains('translate-x-full')) {
            // Cerrado
            overlay.classList.add('opacity-0', 'pointer-events-none');
            setTimeout(() => btnOpen.classList.remove('hidden'), 300);
        } else {
            // Abierto
            overlay.classList.remove('opacity-0', 'pointer-events-none');
            btnOpen.classList.add('hidden');
            refreshCurrentRanking();
        }
    }

    // --- LÓGICA CONFIGURADOR (PASO A PASO) ---
    function setModo(modo, boton) {
        modoJuegoSeleccionado = modo;

        // 1. Efectos visuales de botones (Reset y Selección)
        document.querySelectorAll('.btn-modo').forEach(btn => {
            btn.classList.remove('selected', 'border-amber-500', 'border-indigo-500', 'border-emerald-500', 'border-red-500');
        });
        boton.classList.add('selected');

        if(modo === 'quizz') boton.classList.add('border-amber-500');
        if(modo === 'trivial') boton.classList.add('border-indigo-500');
        if(modo === 'supervivencia') boton.classList.add('border-emerald-500');
        if(modo === 'ruleta') boton.classList.add('border-red-500');

        // 2. Desbloquear el panel inferior quitando el gris
        const panel = document.getElementById("panel-configuracion");
        panel.classList.remove("opacity-40", "grayscale", "pointer-events-none");

        // 3. Reglas específicas
        const selectCat = document.getElementById("select-categoria");
        const selectCues = document.getElementById("select-cuestionario");
        const bloqueCant = document.getElementById("bloque-cantidad");
        const bloqueTime = document.getElementById("bloque-tiempo");
        const bloqueSoc = document.getElementById("bloque-social");
        const selectSoc = document.getElementById("select-modo");

        selectCat.disabled = false;
        bloqueCant.classList.remove("opacity-30", "pointer-events-none");
        bloqueTime.classList.remove("opacity-30", "pointer-events-none");
        bloqueSoc.classList.remove("opacity-30", "pointer-events-none");
        selectSoc.disabled = false;

        if (modo === "ruleta") {
            selectCat.disabled = true; selectCues.disabled = true;
            selectCues.innerHTML = '<option value="RULETA">💀 Ruleta Aleatoria</option>';
            bloqueCant.classList.add("opacity-30", "pointer-events-none");
            bloqueTime.classList.add("opacity-30", "pointer-events-none");
            bloqueSoc.classList.add("opacity-30", "pointer-events-none");
            selectSoc.value = "solo"; selectSoc.disabled = true;
            document.getElementById("div-social-extras").classList.add("hidden");
        } else if (modo === "supervivencia") {
            selectCues.disabled = (selectCat.value === "");
            if(selectCat.value === "") selectCues.innerHTML = '<option value="">Esperando categoría...</option>';
            bloqueCant.classList.add("opacity-30", "pointer-events-none");
            bloqueTime.classList.add("opacity-30", "pointer-events-none");
            bloqueSoc.classList.add("opacity-30", "pointer-events-none");
            selectSoc.value = "solo"; selectSoc.disabled = true;
            document.getElementById("div-social-extras").classList.add("hidden");
        } else {
            selectCues.disabled = (selectCat.value === "");
            if(selectCat.value === "") selectCues.innerHTML = '<option value="">Esperando categoría...</option>';
        }
        validarBoton();
    }

    function validarBoton() {
        const btn = document.getElementById("btn-comenzar");
        const selectCues = document.getElementById("select-cuestionario");

        if (modoJuegoSeleccionado === "ruleta") {
            btn.disabled = false;
        } else {
            btn.disabled = (selectCues.value === "" || modoJuegoSeleccionado === "");
        }

        if(!btn.disabled) {
            btn.classList.remove("bg-slate-200", "dark:bg-slate-800", "text-slate-400", "dark:text-slate-500", "shadow-sm");
            btn.classList.add("bg-gradient-to-r", "from-violet-600", "via-fuchsia-600", "to-pink-500", "text-white", "shadow-[0_8px_0_rgb(147,51,234)]", "hover:translate-y-[2px]", "hover:shadow-[0_6px_0_rgb(147,51,234)]", "active:translate-y-[8px]", "active:shadow-none");
        } else {
            btn.classList.add("bg-slate-200", "dark:bg-slate-800", "text-slate-400", "dark:text-slate-500", "shadow-sm");
            btn.classList.remove("bg-gradient-to-r", "from-violet-600", "via-fuchsia-600", "to-pink-500", "text-white", "shadow-[0_8px_0_rgb(147,51,234)]", "hover:translate-y-[2px]", "hover:shadow-[0_6px_0_rgb(147,51,234)]", "active:translate-y-[8px]", "active:shadow-none");
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        document.getElementById("select-categoria").addEventListener("change", async (e) => {
            const cat = e.target.value;
            const selectCues = document.getElementById("select-cuestionario");
            if(cat && modoJuegoSeleccionado !== "ruleta") {
                selectCues.disabled = true;
                selectCues.innerHTML = '<option>Cargando temas...</option>';
                const res = await fetch(`/Datos/GetCuestionariosJson?nombreCategoria=${encodeURIComponent(cat)}`);
                const data = await res.json();
                selectCues.innerHTML = '<option value="">Elegir Tema...</option>' + data.map(t => `<option value="${t}">${t}</option>`).join('');
                selectCues.disabled = false;
            } else if (!cat) {
                selectCues.innerHTML = '<option value="">Esperando categoría...</option>';
                selectCues.disabled = true;
            }
            validarBoton();
        });

        document.getElementById("select-cuestionario").addEventListener("change", validarBoton);

        document.getElementById("select-modo").addEventListener("change", (e) => {
            const ext = document.getElementById("div-social-extras");
            if (e.target.value === "multi") {
                ext.classList.remove("hidden");
            } else {
                ext.classList.add("hidden");
            }
        });

        document.getElementById("btn-comenzar").addEventListener("click", () => {
            const config = {
                nombreCuestionario: document.getElementById("select-cuestionario").value,
                tipoPartida: modoJuegoSeleccionado,
                cantidad: document.getElementById("select-cantidad").value,
                tiempo: document.getElementById("select-tiempo").value,
                publico: document.getElementById("select-publico")?.value || "true",
                capacidad: document.getElementById("select-capacidad")?.value || "4",
                nivel: document.getElementById("select-nivel").value
            };

            document.getElementById("game-card").classList.add("opacity-50", "pointer-events-none");
            document.getElementById("btn-comenzar").innerHTML = '<i class="bi bi-hourglass-split animate-spin text-2xl"></i> Preparando ...';

            if (document.getElementById("select-modo").value === "multi") {
                const form = document.createElement("form"); form.method = "POST"; form.action = "/SalasMultijugador/CrearSala";
                for (const key in config) {
                    const input = document.createElement("input"); input.type = "hidden"; input.name = key; input.value = config[key];
                    form.appendChild(input);
                }
                document.body.appendChild(form); form.submit();
            } else {
                if (config.tipoPartida === "supervivencia") window.location.href = `/Partidas/ModoSupervivencia?nombreCuestionario=${encodeURIComponent(config.nombreCuestionario)}`;
                else if(config.tipoPartida === "ruleta") window.location.href= '/Partidas/RuletaDeLaMuerte';
                else window.location.href = `/Partidas/Preguntas${config.tipoPartida.charAt(0).toUpperCase() + config.tipoPartida.slice(1)}?nombreCuestionario=${encodeURIComponent(config.nombreCuestionario)}&cantidad=${config.cantidad}&tiempo=${config.tiempo}&nivel=${config.nivel}`;
            }
        });

        document.getElementById("filter-sv-cat").addEventListener("change", refreshCurrentRanking);
        document.getElementById("order-ruleta").addEventListener("change", refreshCurrentRanking);

        setInterval(() => {
            if(!document.getElementById('ranking-drawer').classList.contains('translate-x-full')) {
                refreshCurrentRanking();
            }
        }, 20000);
    });

    function switchRanking(modo) {
        currentRankingMode = modo;
        const tabSv = document.getElementById("tab-sv");
        const tabRuleta = document.getElementById("tab-ruleta");

        if (modo === 'supervivencia') {
            tabSv.className = "flex-1 py-3 text-[11px] font-black uppercase tracking-widest rounded-2xl bg-amber-500 text-white shadow-md transition-all";
            tabRuleta.className = "flex-1 py-3 text-[11px] font-black uppercase tracking-widest rounded-2xl text-slate-400 dark:text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-800 transition-all bg-transparent shadow-none border border-slate-200 dark:border-slate-700";
            document.getElementById("filter-sv-container").classList.remove("hidden");
            document.getElementById("filter-ruleta-container").classList.add("hidden");
        } else {
            tabRuleta.className = "flex-1 py-3 text-[11px] font-black uppercase tracking-widest rounded-2xl bg-red-600 text-white shadow-md transition-all";
            tabSv.className = "flex-1 py-3 text-[11px] font-black uppercase tracking-widest rounded-2xl text-slate-400 dark:text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-800 transition-all bg-transparent shadow-none border border-slate-200 dark:border-slate-700";
            document.getElementById("filter-ruleta-container").classList.remove("hidden");
            document.getElementById("filter-sv-container").classList.add("hidden");
        }
        refreshCurrentRanking();
    }

    async function refreshCurrentRanking() {
        const container = document.getElementById("ranking-body");
        const filtro = currentRankingMode === 'supervivencia' ? document.getElementById("filter-sv-cat").value : "";
        const orden = currentRankingMode === 'ruleta' ? document.getElementById("order-ruleta").value : "desc";

        if(container.innerHTML.trim() === "" || container.innerHTML.includes("El ranking está vacío")) {
            container.innerHTML = Array(5).fill().map(() => `
                <div class="skeleton-item flex items-center p-4 rounded-[1.5rem] bg-slate-100 dark:bg-slate-800/50 mb-3">
                    <div class="w-10 h-10 rounded-full bg-slate-200 dark:bg-slate-700 shrink-0"></div>
                    <div class="ml-4 flex-1 space-y-3">
                        <div class="h-3 bg-slate-200 dark:bg-slate-700 rounded w-1/2"></div>
                        <div class="h-2 bg-slate-200 dark:bg-slate-700 rounded w-1/3"></div>
                    </div>
                </div>
            `).join('');
        }

        try {
            const response = await fetch(`/Datos/GetTopRankings?modo=${currentRankingMode}&filtro=${filtro}&orden=${orden}`);
            const data = await response.json();

            if(!data.length) {
                container.innerHTML = `<div class="text-center py-20 flex flex-col items-center justify-center opacity-40"><i class="bi bi-trophy text-5xl mb-3 dark:text-slate-500"></i><span class="text-xs font-bold uppercase tracking-widest dark:text-slate-500">Aún no hay campeones...</span></div>`;
                return;
            }

            container.innerHTML = data.map((entry, i) => `
                <div class="flex items-center justify-between p-4 mb-3 rounded-[1.5rem] bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 shadow-sm hover:shadow-md hover:border-indigo-400 dark:hover:border-indigo-500 transition-all group animate__animated animate__fadeIn">
                    <div class="flex items-center gap-4 overflow-hidden min-w-0">
                        <span class="text-lg w-6 text-center shrink-0 font-black drop-shadow-sm">${i < 3 ? ['🥇','🥈','🥉'][i] : '<span class="text-xs text-slate-400 dark:text-slate-500">'+(i+1)+'</span>'}</span>
                        <img src="/images/avatares/${entry.avatar}" class="w-12 h-12 rounded-2xl object-cover shrink-0 border-2 ${i < 3 ? 'border-amber-400' : 'border-slate-100 dark:border-slate-700'}" />
                        <div class="flex flex-col min-w-0">
                            <span class="text-sm font-black truncate text-slate-800 dark:text-slate-100">${entry.nombre}</span>
                            <span class="text-[10px] text-slate-400 dark:text-slate-500 uppercase font-black truncate tracking-widest mt-0.5">${entry.cuestionario}</span>
                        </div>
                    </div>
                    <div class="text-right shrink-0 pl-4">
                        <span class="text-xl font-black ${currentRankingMode==='ruleta'?'text-red-500':'text-amber-500'}">${entry.puntos.toLocaleString()}</span>
                    </div>
                </div>
            `).join('');
        } catch(e) {
            console.error("Error cargando ranking:", e);
        }
        function toggleBuzonInvitaciones() {
            const grid = document.getElementById('grid-invitaciones');
            const icono = document.getElementById('icono-buzon');

            // Alternamos la clase oculta de Tailwind
            grid.classList.toggle('hidden');

            // Giramos la flechita 180 grados para que mire hacia abajo cuando se oculta
            if (grid.classList.contains('hidden')) {
                icono.classList.add('rotate-180');
            } else {
                icono.classList.remove('rotate-180');
            }
        }
    }
</script>