@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<div class="min-h-[80vh] flex items-center justify-center bg-slate-50 dark:bg-slate-950 px-6 py-12 transition-colors duration-500">
    <div class="max-w-md w-full bg-white dark:bg-slate-900 p-10 rounded-[3rem] shadow-2xl border border-indigo-100 dark:border-indigo-900/30 animate__animated animate__zoomIn">

        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 rounded-2xl mb-4 shadow-inner">
                <i class="bi bi-shield-lock-fill text-3xl"></i>
            </div>
            <h2 class="text-3xl font-black text-slate-800 dark:text-white">Seguridad</h2>
            <p class="text-slate-500 text-sm mt-2 font-bold">Actualiza tu código de acceso al servidor</p>
        </div>

        @* Zona para mostrar errores si la contraseña antigua no coincide *@
        @if (ViewData["ERROR"] != null)
        {
            <div class="bg-rose-50 dark:bg-rose-900/20 text-rose-600 p-4 rounded-2xl mb-6 font-bold text-sm text-center animate__animated animate__shakeX">
                <i class="bi bi-shield-x mr-2"></i> @ViewData["ERROR"]
            </div>
        }
        @if (ViewData["MENSAJE"] != null)
        {
            <div class="bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 p-4 rounded-2xl mb-6 font-bold text-sm text-center animate__animated animate__fadeIn">
                <i class="bi bi-shield-check mr-2 text-lg"></i> @ViewData["MENSAJE"]
            </div>
        }

        <form asp-action="CambiarPassword" asp-controller="Managed" method="post" class="space-y-6">

            @* Campo: Contraseña Actual *@
            <div class="space-y-2">
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-4">Contraseña Actual</label>
                <div class="relative group">
                    <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-slate-600 dark:group-focus-within:text-slate-300 transition-colors">
                        <i class="bi bi-unlock-fill text-xl"></i>
                    </span>
                    <input type="password" name="oldPassword" required
                           class="w-full bg-slate-50 dark:bg-slate-800 border-2 border-transparent focus:border-slate-300 dark:focus:border-slate-600 dark:text-white rounded-2xl py-4 pl-14 pr-6 font-bold outline-none transition-all shadow-inner"
                           placeholder="Tu clave de siempre" />
                </div>
            </div>

            <div class="h-px bg-slate-100 dark:bg-slate-800 w-full my-6"></div>

            @* Campo: Nueva Contraseña *@
            <div class="space-y-2">
                <label class="block text-[10px] font-black text-indigo-400 uppercase tracking-widest ml-4">Nueva Contraseña</label>
                <div class="relative group">
                    <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                        <i class="bi bi-key-fill text-xl"></i>
                    </span>
                    <input type="password" name="newPassword" required minlength="6"
                           class="w-full bg-indigo-50/30 dark:bg-indigo-900/10 border-2 border-transparent focus:border-indigo-500 dark:text-white rounded-2xl py-4 pl-14 pr-6 font-bold outline-none transition-all shadow-inner"
                           placeholder="Mínimo 6 caracteres" />
                </div>
            </div>

            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-black py-5 rounded-[2rem] text-lg shadow-[0_8px_0_rgb(79,70,229)] active:shadow-none active:translate-y-[8px] transition-all flex justify-center items-center gap-2 mt-4">
                GUARDAR CAMBIOS <i class="bi bi-check2-circle text-xl"></i>
            </button>
        </form>

        <div class="mt-8 text-center">
            <a asp-controller="Managed" asp-action="Perfil" class="text-xs font-black text-slate-400 hover:text-indigo-600 uppercase tracking-widest transition-colors">
                <i class="bi bi-arrow-left"></i> Volver a mi perfil
            </a>
        </div>
    </div>
</div>