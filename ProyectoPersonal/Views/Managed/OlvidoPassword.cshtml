@{
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="min-h-screen flex items-center justify-center bg-slate-50 dark:bg-slate-950 px-6 py-12 transition-colors duration-500">
    <div class="max-w-md w-full bg-white dark:bg-slate-900 p-10 rounded-[3rem] shadow-2xl border border-orange-100 dark:border-orange-900/30 animate__animated animate__fadeInUp">

        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-orange-100 dark:bg-orange-900/30 text-orange-600 rounded-2xl mb-4 shadow-inner">
                <i class="bi bi-envelope-exclamation-fill text-3xl"></i>
            </div>
            <h2 class="text-3xl font-black text-slate-800 dark:text-white">Rescate de Cuenta</h2>
            <p class="text-slate-500 text-sm mt-2 font-bold">Introduce tu email de comandante</p>
        </div>

        @if (ViewBag.Mensaje != null)
        {
            <div class="bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 p-4 rounded-2xl mb-6 font-bold text-sm text-center">
                <i class="bi bi-send-check-fill mr-2"></i> @ViewBag.Mensaje
            </div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="bg-rose-50 dark:bg-rose-900/20 text-rose-600 p-4 rounded-2xl mb-6 font-bold text-sm text-center">
                <i class="bi bi-exclamation-triangle-fill mr-2"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="OlvidoPassword" asp-controller="Managed" method="post" class="space-y-6">
            <div class="space-y-2">
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-4">Correo Electrónico</label>
                <div class="relative group">
                    <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-orange-500 transition-colors">
                        <i class="bi bi-at text-xl"></i>
                    </span>
                    <input type="email" name="email" required
                           class="w-full bg-slate-50 dark:bg-slate-800 border-2 border-transparent focus:border-orange-500 dark:text-white rounded-2xl py-4 pl-14 pr-6 font-bold outline-none transition-all shadow-inner"
                           placeholder="tu@email.com" />
                </div>
            </div>

            <button type="submit" class="w-full bg-orange-600 hover:bg-orange-500 text-white font-black py-5 rounded-[2rem] text-lg shadow-[0_8px_0_rgb(154,52,18)] active:shadow-none active:translate-y-[8px] transition-all flex justify-center items-center gap-2">
                ENVIAR ENLACE <i class="bi bi-rocket-fill"></i>
            </button>
        </form>

        <div class="mt-8 text-center">
            <a asp-action="Login" asp-controller="Managed" class="text-xs font-black text-slate-400 hover:text-orange-600 uppercase tracking-widest transition-colors">
                <i class="bi bi-arrow-left"></i> Volver a la base
            </a>
        </div>
    </div>
</div>