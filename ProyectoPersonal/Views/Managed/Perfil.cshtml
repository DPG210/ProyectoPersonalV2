@model ProyectoPersonal.Models.InformacionUsuario
@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@using ProyectoPersonal.Models
@{
    int? idLogueado = int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0");
    bool esMiPerfil = ViewBag.EsMiPerfil ?? false;
}

<div class="max-w-6xl mx-auto px-4 py-12 space-y-10 font-sans text-slate-800 dark:text-slate-200 transition-colors duration-500">

    <div class="flex justify-start">
        <a asp-controller="Partidas" asp-action="Index" class="bg-white dark:bg-slate-900 text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 font-black text-xs uppercase tracking-widest px-6 py-3 rounded-full shadow-sm border border-slate-200 dark:border-slate-800 transition-all flex items-center gap-2 transform hover:-translate-x-1">
            <i class="bi bi-arrow-left text-lg"></i> Volver
        </a>
    </div>

    <div class="relative bg-white dark:bg-slate-900 rounded-[3rem] shadow-2xl shadow-indigo-100/50 dark:shadow-black/50 overflow-hidden border border-slate-100 dark:border-slate-800 transition-colors duration-300">
        <div class="h-44 bg-gradient-to-br from-violet-600 via-indigo-600 to-fuchsia-500 relative">
            <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
            <div class="absolute -bottom-1 left-0 w-full h-16 bg-gradient-to-t from-white dark:from-slate-900 to-transparent transition-colors"></div>
        </div>

        <div class="px-6 md:px-10 pb-10 flex flex-col md:flex-row items-center md:items-end -mt-20 gap-8 relative z-10">

            <div class="relative group @(esMiPerfil ? "cursor-pointer" : "")" onclick="@(esMiPerfil ? "abrirModalAvatar()" : "")">
                <div class="p-2 bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-2xl transform transition-all duration-500 group-hover:scale-105 group-hover:rotate-2 relative overflow-hidden">
                    <img src="~/images/avatares/@Model.Avatar"
                         class="w-32 h-32 md:w-40 md:h-40 rounded-[2rem] bg-slate-50 dark:bg-slate-900 border-4 border-white dark:border-slate-700 shadow-inner object-cover transition-colors" />

                    @if (esMiPerfil)
                    {
                        <div class="absolute inset-2 bg-black/60 rounded-[2rem] flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                            <i class="bi bi-pencil-fill text-white text-3xl mb-1 drop-shadow-md"></i>
                            <span class="text-white text-xs font-bold uppercase tracking-widest drop-shadow-md">Cambiar</span>
                        </div>
                    }
                </div>
                <div class="absolute bottom-4 right-4 w-6 h-6 md:w-8 md:h-8 bg-emerald-500 border-4 border-white dark:border-slate-800 rounded-full shadow-lg animate-pulse transition-colors"></div>
            </div>

            <div class="text-center md:text-left flex-grow space-y-2">
                <h1 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tighter transition-colors">
                    @Model.Nombre
                    @if (User.IsInRole("PREMIUM"))
                    {
                        <span class="text-3xl text-amber-500 drop-shadow-sm" title="Usuario VIP">👑</span>
                    }
                    @if ( User.IsInRole("ADMIN"))
                    {
                        <span class="text-3xl text-amber-500 drop-shadow-sm" title="Usuario Admin">Admin</span>
                    }
                </h1>
                <p class="text-slate-400 dark:text-slate-500 font-bold flex items-center justify-center md:justify-start gap-2 transition-colors">
                    <i class="bi bi-envelope-fill text-indigo-400"></i> @Model.Email
                </p>
            </div>

            @if (esMiPerfil)
            {
                <div class="flex flex-col gap-3 items-center md:items-end w-full md:w-auto">

                    <div class="flex flex-wrap justify-center md:justify-end gap-2 w-full">
                        <a asp-controller="Creador" asp-action="CreateCuestionario" class="bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-600 dark:hover:bg-indigo-500 hover:text-white font-black text-xs uppercase tracking-wider px-4 py-2 rounded-2xl shadow-sm border border-indigo-100 dark:border-indigo-800 transition-all flex items-center gap-1.5 group">
                            <i class="bi bi-plus-circle-fill group-hover:rotate-90 transition-transform"></i> Crear Cuestionario
                        </a>
                        <a asp-controller="Tienda" asp-action="Index" class="bg-gradient-to-r from-amber-400 to-orange-500 hover:from-amber-500 hover:to-orange-600 text-white font-black text-xs uppercase tracking-wider px-4 py-2 rounded-2xl shadow-md border border-orange-400 transition-transform hover:-translate-y-0.5 flex items-center gap-1.5">
                            <i class="bi bi-star-fill animate-pulse"></i> Tienda VIP
                        </a>
                        <a asp-controller="Managed" asp-action="CambiarPassword" class="inline-flex items-center gap-2 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-indigo-600 hover:text-white dark:hover:bg-indigo-500 px-5 py-3 rounded-2xl text-xs font-black uppercase tracking-widest shadow-sm transition-all mt-4">
                            <i class="bi bi-shield-lock-fill text-base"></i> Cambiar Contraseña
                        </a>
                        <button type="button" onclick="confirmarBorradoCuenta()" class="bg-rose-50 dark:bg-rose-950/30 text-rose-600 dark:text-rose-400 hover:bg-rose-600 dark:hover:bg-rose-600 hover:text-white dark:hover:text-white font-black text-xs uppercase tracking-wider px-4 py-2 rounded-2xl shadow-sm border border-rose-100 dark:border-rose-900/50 transition-all flex items-center gap-1.5 group">
                            <i class="bi bi-trash3-fill group-hover:scale-110 transition-transform"></i> Borrar Cuenta
                        </button>
                    </div>

                    <form id="form-borrar-cuenta" asp-controller="Managed" asp-action="DeleteUsuario" method="post" class="hidden">
                        <input type="hidden" name="idUsuario" value="@Model.IdUsuario" />
                    </form>

                    <div class="bg-rose-50 dark:bg-slate-800 border-2 border-rose-100 dark:border-rose-900/30 px-6 py-3 rounded-2xl shadow-lg shadow-rose-100/40 dark:shadow-black/30 flex items-center gap-3 transition-all hover:scale-105 w-full md:w-auto justify-center">
                        <span class="text-3xl drop-shadow-md animate-pulse">❤️</span>
                        <div class="flex flex-col text-left">
                            <span class="text-2xl font-black text-slate-800 dark:text-white leading-none transition-colors">@Model.Corazones</span>
                            <span class="text-[9px] font-black text-rose-500 dark:text-rose-400 uppercase tracking-widest mt-0.5">Vitalidad</span>
                        </div>
                    </div>

                </div>
            }
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-slate-900 p-8 rounded-[2.5rem] shadow-xl shadow-slate-200/50 dark:shadow-black/30 border border-slate-100 dark:border-slate-800 text-center group hover:-translate-y-2 transition-all duration-300">
            <div class="w-14 h-14 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-500 dark:text-indigo-400 rounded-2xl flex items-center justify-center mx-auto mb-4 text-3xl shadow-sm group-hover:bg-indigo-500 group-hover:text-white transition-colors">
                <i class="bi bi-rocket-takeoff"></i>
            </div>
            <div class="text-4xl font-black text-slate-900 dark:text-white transition-colors">@ViewBag.TotalPartidas</div>
            <div class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mt-2">Incursiones Totales</div>
        </div>

        <div class="bg-white dark:bg-slate-900 p-8 rounded-[2.5rem] shadow-xl shadow-slate-200/50 dark:shadow-black/30 border border-slate-100 dark:border-slate-800 text-center group hover:-translate-y-2 transition-all duration-300">
            <div class="w-14 h-14 bg-emerald-50 dark:bg-emerald-900/30 text-emerald-500 dark:text-emerald-400 rounded-2xl flex items-center justify-center mx-auto mb-4 text-3xl shadow-sm group-hover:bg-emerald-500 group-hover:text-white transition-colors">
                <i class="bi bi-shield-check"></i>
            </div>
            <div class="text-4xl font-black text-slate-900 dark:text-white transition-colors">@ViewBag.TotalAciertos</div>
            <div class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mt-2">Objetivos Logrados</div>
        </div>

        <div class="bg-white dark:bg-slate-900 p-8 rounded-[2.5rem] shadow-xl shadow-slate-200/50 dark:shadow-black/30 border border-slate-100 dark:border-slate-800 text-center group hover:-translate-y-2 transition-all duration-300">
            <div class="w-14 h-14 bg-amber-50 dark:bg-amber-900/30 text-amber-500 dark:text-amber-400 rounded-2xl flex items-center justify-center mx-auto mb-4 text-3xl shadow-sm group-hover:bg-amber-500 group-hover:text-white transition-colors">
                <i class="bi bi-lightning-charge"></i>
            </div>
            <div class="text-4xl font-black text-slate-900 dark:text-white transition-colors">@ViewBag.PorcentajeExito<span class="text-xl text-slate-300 dark:text-slate-600">%</span></div>
            <div class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mt-2">Ratio de Éxito</div>
        </div>
    </div>

    <div class="bg-slate-200/50 dark:bg-slate-900 p-2 rounded-[2rem] w-full max-w-3xl mx-auto backdrop-blur-md border border-slate-200 dark:border-slate-800 flex justify-between gap-2 shadow-inner transition-colors">
        <button onclick="toggleTab('stats')" id="tab-btn-stats"
                class="tab-btn flex-grow px-8 py-4 rounded-[1.5rem] font-black text-[11px] uppercase tracking-[0.2em] transition-all flex items-center justify-center gap-2">
            <i class="bi bi-journal-text text-lg"></i> Historial
        </button>
        <button onclick="toggleTab('rankings')" id="tab-btn-rankings"
                class="tab-btn flex-grow px-8 py-4 rounded-[1.5rem] font-black text-[11px] uppercase tracking-[0.2em] transition-all flex items-center justify-center gap-2">
            <i class="bi bi-trophy text-lg"></i> Récords
        </button>
        @if (esMiPerfil)
        {
            <button onclick="toggleTab('social')" id="tab-btn-social"
                    class="tab-btn flex-grow px-8 py-4 rounded-[1.5rem] font-black text-[11px] uppercase tracking-[0.2em] transition-all flex items-center justify-center gap-2">
                <i class="bi bi-people text-lg"></i> Amistades
            </button>
        }
    </div>

    <div id="content-stats" class="tab-content hidden space-y-10 animate__animated animate__fadeIn">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
            <div class="space-y-6">
                <h3 class="text-xl font-black text-slate-800 dark:text-white uppercase tracking-[0.2em] flex items-center gap-3 transition-colors">
                    <span class="w-1.5 h-6 bg-indigo-500 rounded-full"></span> Misiones Solo
                </h3>
                <div class="space-y-3">
                    @if (ViewBag.Historial != null)
                    {
                        foreach (HistorialIndividualPartidas p in ViewBag.Historial)
                        {
                            <div class="bg-white dark:bg-slate-900 p-5 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-800 flex items-center justify-between hover:shadow-md hover:border-indigo-200 dark:hover:border-indigo-800 transition-all group">
                                <div class="flex items-center gap-5">
                                    <div class="w-12 h-12 bg-slate-50 dark:bg-slate-800 text-slate-400 dark:text-slate-500 rounded-2xl flex items-center justify-center text-xl group-hover:bg-indigo-50 dark:group-hover:bg-indigo-900/30 group-hover:text-indigo-500 transition-colors">
                                        <i class="bi bi-file-earmark-text"></i>
                                    </div>
                                    <div>
                                        <h4 class="font-black text-slate-700 dark:text-slate-200 leading-tight transition-colors">@p.NombreCuestionario</h4>
                                        <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mt-1">Finalizada el @p.FechaFinalizacion.ToString("dd/MM/yyyy")</p>
                                    </div>
                                </div>
                                <div class="bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 px-5 py-2 rounded-2xl font-black text-sm border border-indigo-100 dark:border-indigo-800/50 transition-colors">
                                    @p.PreguntasCorrectas <span class="text-indigo-300 dark:text-indigo-700 mx-1">/</span> @p.PreguntasTotales
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="space-y-6">
                <h3 class="text-xl font-black text-slate-800 dark:text-white uppercase tracking-[0.2em] flex items-center gap-3 transition-colors">
                    <span class="w-1.5 h-6 bg-fuchsia-500 rounded-full"></span> Escaramuzas PvP
                </h3>
                <div class="space-y-3">
                    @if (ViewBag.HistorialMulti != null)
                    {
                        foreach (ProyectoPersonal.Models.HistorialMultiPartida p in ViewBag.HistorialMulti)
                        {
                            <div class="bg-white dark:bg-slate-900 p-5 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-800 flex items-center justify-between hover:shadow-md hover:border-fuchsia-200 dark:hover:border-fuchsia-800 transition-all">
                                <div class="flex items-center gap-5">
                                    <div class="w-12 h-12 bg-slate-50 dark:bg-slate-800 text-slate-400 dark:text-slate-500 rounded-2xl flex items-center justify-center text-xl transition-colors">
                                        <i class="bi bi-lightning-fill text-amber-500 dark:text-amber-400"></i>
                                    </div>
                                    <div>
                                        <h4 class="font-black text-slate-700 dark:text-slate-200 leading-tight transition-colors">@p.NombreCuestionario</h4>
                                        <div class="flex -space-x-2 mt-2">
                                            @foreach (var jug in p.Participantes.Take(3))
                                            {
                                                <div class="w-7 h-7 rounded-full border-2 border-white dark:border-slate-900 bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-[8px] font-black text-slate-500 dark:text-slate-300 shadow-sm" title="@jug.Nombre">
                                                    @jug.Nombre.Substring(0, 1).ToUpper()
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="text-right">
                                    @if (p.Ganador == Model.Nombre)
                                    {
                                        <span class="bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 px-4 py-2 rounded-2xl text-[10px] font-black border border-amber-200 dark:border-amber-700/50 flex items-center gap-1 transition-colors">🏆 VICTORIA</span>
                                    }
                                    else
                                    {
                                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Derrota</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div id="content-rankings" class="tab-content hidden animate__animated animate__fadeIn">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            @if (ViewBag.RankingModos != null && ((IEnumerable<dynamic>)ViewBag.RankingModos).Any())
            {
                foreach (ProyectoPersonal.Models.RankingModo rank in ViewBag.RankingModos)
                {
                    <div class="bg-slate-900 dark:bg-black p-10 rounded-[3rem] shadow-2xl border border-red-900/20 group relative overflow-hidden transition-colors">
                        <div class="absolute -right-8 -top-8 text-red-600 opacity-10 transform rotate-12 group-hover:rotate-0 transition-transform duration-700">
                            <i class="bi bi-skull-fill text-[12rem]"></i>
                        </div>
                        <div class="relative z-10 space-y-5">
                            <span class="px-4 py-1.5 bg-red-600/20 text-red-500 rounded-2xl text-[10px] font-black uppercase tracking-widest border border-red-500/30 inline-block">
                                @rank.ModoJuego
                            </span>
                            <h4 class="text-6xl font-black text-white tracking-tighter">@rank.Puntos <span class="text-xl text-red-900 font-bold uppercase tracking-widest">Pts</span></h4>
                            <p class="text-sm font-bold text-slate-400 italic">"@rank.NombreCuestionario"</p>
                            <div class="pt-6 border-t border-slate-800 text-[10px] text-slate-500 font-black uppercase tracking-[0.2em] flex items-center gap-2">
                                <i class="bi bi-calendar3"></i> @rank.FechaPartida.ToString("dd MMM yyyy")
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div id="content-social" class="tab-content hidden space-y-12 animate__animated animate__fadeIn">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

            <div class="lg:col-span-7 bg-white dark:bg-slate-900 p-10 rounded-[3rem] shadow-2xl shadow-indigo-100/50 dark:shadow-black/50 border border-slate-100 dark:border-slate-800 transition-colors duration-300">
                <h5 class="text-2xl font-black text-slate-900 dark:text-white mb-8 flex items-center gap-3 transition-colors">
                    <i class="bi bi-search-heart text-indigo-500 text-3xl"></i> Reclutar Aliados
                </h5>

                <form id="form-buscador" class="relative">
                    <input type="text" id="input-busqueda" class="w-full bg-slate-100 dark:bg-slate-950 border-2 border-transparent focus:border-indigo-500 dark:focus:border-indigo-500 rounded-[2rem] py-6 px-10 font-bold text-slate-700 dark:text-slate-200 outline-none transition-all text-lg shadow-inner placeholder-slate-400 dark:placeholder-slate-600" placeholder="Busca por nombre de usuario..." />
                    <button type="submit" class="absolute right-3 top-3 bottom-3 bg-indigo-600 hover:bg-indigo-700 text-white font-black px-10 rounded-3xl transition-all active:scale-95 text-xs tracking-widest shadow-lg">
                        BUSCAR
                    </button>
                </form>

                <div id="contenedor-resultados" class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-4">
                </div>
            </div>

            <div class="lg:col-span-5 space-y-8">
                @if (ViewBag.Solicitudes != null && ((List<UsuarioAmistad>)ViewBag.Solicitudes).Count > 0)
                {
                    <div class="bg-rose-50 dark:bg-slate-900 p-8 rounded-[3rem] border-2 border-rose-100 dark:border-slate-800 shadow-xl shadow-rose-100/20 dark:shadow-black/30 transition-colors duration-300">
                        <h5 class="text-xs font-black text-rose-500 dark:text-rose-400 uppercase tracking-[0.3em] mb-6 flex items-center gap-3">
                            <i class="bi bi-envelope-exclamation-fill text-xl"></i> Solicitudes Entrantes
                        </h5>
                        <div class="space-y-3">
                            @foreach (var sol in (List<UsuarioAmistad>)ViewBag.Solicitudes)
                            {
                                <div class="flex justify-between items-center bg-white dark:bg-slate-800 p-4 rounded-3xl shadow-sm border border-rose-100 dark:border-slate-700 transition-colors">
                                    <span class="font-black text-slate-700 dark:text-slate-200 ml-2">@sol.Nombre</span>
                                    <div class="flex gap-2">
                                        <a asp-controller="Social" asp-action="AceptarAmigo" asp-route-idAmigo="@sol.IdUsuario" class="bg-emerald-500 text-white p-3 rounded-2xl hover:bg-emerald-600 shadow-lg shadow-emerald-100 dark:shadow-emerald-900/30 transition-all"><i class="bi bi-check-lg"></i></a>
                                        <a asp-controller="Social" asp-action="RechazarAmigo" asp-route-idAmigo="@sol.IdUsuario" class="bg-rose-500 text-white p-3 rounded-2xl hover:bg-rose-600 shadow-lg shadow-rose-100 dark:shadow-rose-900/30 transition-all"><i class="bi bi-x-lg"></i></a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="bg-white dark:bg-slate-900 p-10 rounded-[3rem] shadow-2xl shadow-indigo-100/30 dark:shadow-black/50 border border-slate-100 dark:border-slate-800 transition-colors duration-300">
                    <h5 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.3em] mb-10 flex items-center gap-3">
                        <i class="bi bi-person-lines-fill text-indigo-500 text-xl"></i> Aliados de Confianza
                    </h5>
                    <div class="space-y-6">
                        @if (ViewBag.Amigos != null)
                        {
                            foreach (string amigo in ViewBag.Amigos)
                            {
                                <div class="flex items-center justify-between group p-3 rounded-3xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-all border border-transparent hover:border-slate-100 dark:hover:border-slate-700">
                                    <div class="flex items-center gap-4">
                                        <div class="relative">
                                            <div class="w-12 h-12 rounded-2xl bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center font-black text-indigo-600 dark:text-indigo-400 text-xl shadow-sm transition-colors">@amigo.Substring(0, 1).ToUpper()</div>
                                            <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-500 border-2 border-white dark:border-slate-900 rounded-full transition-colors"></div>
                                        </div>
                                        <span class="font-black text-slate-800 dark:text-white text-lg transition-colors">@amigo</span>
                                    </div>
                                    <button class="text-rose-400 opacity-0 group-hover:opacity-100 text-[10px] font-black tracking-[0.2em] px-5 py-2 hover:text-rose-600 dark:hover:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-900/30 rounded-2xl transition-all">RETIRAR</button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-10 text-slate-400 dark:text-slate-500 opacity-50 italic font-bold">Sin aliados todavía.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (esMiPerfil)
{
    <div id="modalAvatar" class="hidden fixed inset-0 bg-slate-900/80 z-50 flex items-center justify-center p-4 backdrop-blur-md transition-opacity">
        <div class="bg-white dark:bg-slate-900 rounded-[3rem] shadow-2xl w-full max-w-3xl overflow-hidden border border-slate-100 dark:border-slate-800 animate-fade-in-down transition-colors">
            <div class="bg-slate-50 dark:bg-slate-950 p-8 flex justify-between items-center border-b border-slate-100 dark:border-slate-800 transition-colors">
                <h3 class="font-black text-slate-800 dark:text-white text-2xl tracking-tighter transition-colors"><i class="bi bi-person-bounding-box text-indigo-500 mr-3"></i>Cambiar Avatar</h3>
                <button onclick="cerrarModalAvatar()" class="text-slate-400 hover:text-rose-500 dark:hover:text-rose-400 font-bold text-3xl transition-colors">&times;</button>
            </div>

            <div class="p-10">
                <form asp-action="CambiarAvatar" asp-controller="Managed" method="post">
                    <input type="hidden" id="inputAvatarSeleccionado" name="nombreAvatar" value="" />

                    <div class="grid grid-cols-3 sm:grid-cols-4 gap-6 mb-10">
                        @for (int i = 1; i <= 12; i++)
                        {
                            string imgName = $"avatar{i}.png";
                            <div class="avatar-option cursor-pointer rounded-3xl p-2 border-4 border-transparent hover:border-indigo-200 dark:hover:border-indigo-500/50 transition-all transform hover:scale-105 hover:shadow-lg bg-slate-50 dark:bg-slate-800"
                                 onclick="seleccionarAvatar(this, '@imgName')">
                                <img src="~/images/avatares/@imgName" class="w-full h-auto rounded-2xl object-cover" />
                            </div>
                        }
                    </div>

                    <button type="submit" id="btnGuardarAvatar" class="w-full bg-gradient-to-r from-violet-600 via-indigo-600 to-fuchsia-500 hover:from-violet-500 hover:via-indigo-500 hover:to-fuchsia-400 text-white font-black py-5 rounded-[2rem] text-lg transition-all disabled:opacity-50 disabled:grayscale shadow-[0_10px_40px_-10px_rgba(79,70,229,0.5)] flex justify-center items-center gap-2" disabled>
                        <i class="bi bi-floppy-fill"></i> GUARDAR CAMBIOS
                    </button>
                </form>
            </div>
        </div>
    </div>
}

<script>
    function toggleTab(tabName) {
        document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));

        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('bg-white', 'dark:bg-slate-800', 'shadow-2xl', 'text-indigo-600', 'dark:text-indigo-400', 'scale-105', 'border-indigo-100', 'dark:border-indigo-800');
            btn.classList.add('text-slate-500', 'dark:text-slate-400');
        });

        const content = document.getElementById('content-' + tabName);
        if(content) content.classList.remove('hidden');

        const activeBtn = document.getElementById('tab-btn-' + tabName);
        if(activeBtn) {
            activeBtn.classList.add('bg-white', 'dark:bg-slate-800', 'shadow-2xl', 'text-indigo-600', 'dark:text-indigo-400', 'scale-105', 'border-indigo-100', 'dark:border-indigo-800');
            activeBtn.classList.remove('text-slate-500', 'dark:text-slate-400');
        }
    }

    function abrirModalAvatar() {
        document.getElementById('modalAvatar').classList.remove('hidden');
    }

    function cerrarModalAvatar() {
        document.getElementById('modalAvatar').classList.add('hidden');
    }

    function seleccionarAvatar(elemento, nombreImagen) {
        document.querySelectorAll('.avatar-option').forEach(el => {
            el.classList.remove('border-indigo-500', 'bg-indigo-50', 'dark:bg-indigo-900/30', 'shadow-inner');
            el.classList.add('border-transparent', 'bg-slate-50', 'dark:bg-slate-800');
        });

        elemento.classList.remove('border-transparent', 'bg-slate-50', 'dark:bg-slate-800');
        elemento.classList.add('border-indigo-500', 'bg-indigo-50', 'dark:bg-indigo-900/30', 'shadow-inner');

        document.getElementById('inputAvatarSeleccionado').value = nombreImagen;
        document.getElementById('btnGuardarAvatar').disabled = false;
    }

    function confirmarBorradoCuenta() {
        const isDark = document.documentElement.classList.contains('dark');
        const bgColor = isDark ? '#0f172a' : '#ffffff';
        const textColor = isDark ? '#f8fafc' : '#1e293b';

        Swal.fire({
            title: '¿Destruir tu cuenta?',
            text: "Esta acción es irreversible. Se perderán tus datos.",
            icon: 'warning',
            background: bgColor,
            color: textColor,
            showCancelButton: true,
            confirmButtonColor: '#e11d48',
            confirmButtonText: 'Sí, iniciar purga',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.fire({
                    title: '¡ÚLTIMO AVISO!',
                    text: "Escribe 'CONFIRMAR' para aniquilar la cuenta.",
                    input: 'text',
                    icon: 'error',
                    background: bgColor,
                    color: textColor,
                    showCancelButton: true,
                    confirmButtonText: 'ANIQUILAR',
                    preConfirm: (inputValue) => {
                        if (inputValue !== 'CONFIRMAR') {
                            Swal.showValidationMessage('Debes escribir CONFIRMAR en mayúsculas.');
                        }
                    }
                }).then((secondResult) => {
                    if (secondResult.isConfirmed) {
                        document.getElementById('form-borrar-cuenta').submit();
                    }
                });
            }
        });
    }

    async function ejecutarBusquedaUsuarios(event) {
        event.preventDefault();

        const inputBusqueda = document.getElementById("input-busqueda");
        const textoBusqueda = inputBusqueda.value;
        const contenedorResultados = document.getElementById("contenedor-resultados");

        if (textoBusqueda.length < 3) return;

        contenedorResultados.innerHTML = `
            <div class="col-span-2 text-center py-10 animate-pulse">
                <i class="bi bi-search text-4xl text-indigo-500 mb-2"></i>
                <p class="text-xs font-black uppercase tracking-widest">Escaneando red de aliados...</p>
            </div>`;

        try {
            const response = await fetch(`/Managed/BuscarUsuarios?textoBusqueda=${encodeURIComponent(textoBusqueda)}`);
            const usuarios = await response.json();

            contenedorResultados.innerHTML = "";

            if (usuarios.length === 0) {
                contenedorResultados.innerHTML = `<div class="col-span-2 text-center py-10 opacity-50 italic">No se encontraron resultados.</div>`;
                return;
            }

            usuarios.forEach((user) => {
                const cardHtml = `
                    <div class="p-6 bg-slate-50 dark:bg-slate-800 rounded-[2.5rem] border-2 border-transparent hover:border-indigo-100 dark:hover:border-indigo-500/50 transition-all group flex flex-col items-center text-center animate__animated animate__fadeIn">
                        <img src="/images/avatares/${user.avatar}" class="w-20 h-20 bg-white dark:bg-slate-900 rounded-3xl shadow-md mb-4 object-cover border-2 border-slate-100 dark:border-slate-700" />
                        <span class="font-black text-slate-800 dark:text-white text-xl mb-6">${user.nombre}</span>
                        <div class="flex gap-2 w-full">
                            <a href="/Managed/Perfil/${user.idUsuario}" class="flex-grow flex items-center justify-center py-3 bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-300 rounded-2xl text-[10px] font-black uppercase tracking-widest border border-slate-200 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-700 transition-all cursor-pointer">Perfil</a>
                            <a href="/Social/EnviarInvitacion?idDestino=${user.idUsuario}" class="flex-grow flex items-center justify-center py-3 bg-indigo-600 text-white rounded-2xl text-lg shadow-lg hover:bg-indigo-700 transition-all"><i class="bi bi-person-plus-fill"></i></a>
                        </div>
                    </div>`;
                contenedorResultados.insertAdjacentHTML('beforeend', cardHtml);
            });

        } catch (error) {
            console.error("Error en búsqueda:", error);
            contenedorResultados.innerHTML = `<div class="col-span-2 text-center text-rose-500 font-bold">Error al conectar con el servidor.</div>`;
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        let tabActiva = '@(ViewBag.TabActiva ?? "stats")';
        toggleTab(tabActiva);

        const formSocial = document.getElementById("form-buscador");
        if (formSocial) {
            formSocial.addEventListener("submit", ejecutarBusquedaUsuarios);
        }
    });
</script>