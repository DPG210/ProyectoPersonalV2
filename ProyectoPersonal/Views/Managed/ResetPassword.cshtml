@{
    ViewData["Title"] = "Nueva Contraseña";
}

<div class="min-h-screen flex items-center justify-center bg-slate-50 dark:bg-slate-950 px-6 py-12 transition-colors duration-500">
    <div class="max-w-md w-full bg-white dark:bg-slate-900 p-10 rounded-[3rem] shadow-2xl border border-fuchsia-100 dark:border-fuchsia-900/30 animate__animated animate__zoomIn">

        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-fuchsia-100 dark:bg-fuchsia-900/30 text-fuchsia-600 rounded-2xl mb-4 shadow-inner">
                <i class="bi bi-shield-lock-fill text-3xl"></i>
            </div>
            <h2 class="text-3xl font-black text-slate-800 dark:text-white">Nueva Clave</h2>
            <p class="text-slate-500 text-sm mt-2 font-bold">Asegura tu cuenta con una nueva contraseña</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-rose-50 dark:bg-rose-900/20 text-rose-600 p-4 rounded-2xl mb-6 font-bold text-sm text-center">
                <i class="bi bi-shield-x mr-2"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="ResetPassword" asp-controller="Managed" method="post" class="space-y-6">
            @* EL TOKEN VIAJA OCULTO PARA PODER ENVIARLO AL PROCEDIMIENTO ALMACENADO *@
            <input type="hidden" name="token" value="@ViewBag.Token" />

            <div class="space-y-2">
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-4">Tu nueva contraseña</label>
                <div class="relative group">
                    <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-fuchsia-500 transition-colors">
                        <i class="bi bi-key-fill text-xl"></i>
                    </span>
                    <input type="password" name="password" required minlength="6"
                           class="w-full bg-slate-50 dark:bg-slate-800 border-2 border-transparent focus:border-fuchsia-500 dark:text-white rounded-2xl py-4 pl-14 pr-6 font-bold outline-none transition-all shadow-inner"
                           placeholder="••••••••" />
                </div>
            </div>

            <button type="submit" class="w-full bg-fuchsia-600 hover:bg-fuchsia-500 text-white font-black py-5 rounded-[2rem] text-lg shadow-[0_8px_0_rgb(192,38,211)] active:shadow-none active:translate-y-[8px] transition-all flex justify-center items-center gap-2">
                ACTUALIZAR <i class="bi bi-check2-circle text-xl"></i>
            </button>
        </form>
    </div>
</div>